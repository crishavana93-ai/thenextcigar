---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SubscribeModal from "../components/SubscribeModal.astro";
import CookieBanner from "../components/CookieBanner.astro";
import TravelSheet from "../components/lounge/TravelSheet.astro";
// ClientRouter (view transitions) was removed 2026-05-10 because it was
// preventing MailerLite forms, Astro <Image> components, and the Snipcart
// cart from re-mounting on client-side navigation — symptom: forms invisible
// until page refresh, post images not showing on category pages. Full page
// loads add ~200ms per nav but everything else works without further patches.
// import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  noIndex?: boolean;
  /** When true, skips the public site Header + Footer. Lounge pages render their own. */
  bareChrome?: boolean;
}

const {
  title = "The Next Cigar — Modern stories for the cigar aficionado",
  description = "A modern editorial home for cigar culture, history, gear, and the smoke that ties them together. Reviews, deep dives, and the news that matters.",
  image = "/og-default.svg",
  canonicalURL = new URL(Astro.url.pathname, Astro.site).toString(),
  noIndex = false,
  bareChrome = false,
} = Astro.props as Props;

const siteName = "The Next Cigar";

// Auto-detect Lounge surfaces so they render without the public magazine
// header + footer bleeding through. Covers:
//   • the member app           (/lounge/app/**)
//   • the dedicated auth pages (/lounge/login, /lounge/signup)
// Visitors on these pages are already inside The Lounge — either signed-in
// members or someone mid-onboarding — so the magazine chrome is noise.
// The /lounge/ marketing landing page still keeps the public chrome.
const path = Astro.url.pathname;
const isLoungeApp =
  path.startsWith("/lounge/app") ||
  path.startsWith("/lounge/login") ||
  path.startsWith("/lounge/signup");
const skipPublicChrome = bareChrome || isLoungeApp;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- PWA — installable as an app on iOS, Android, and desktop -->
    {/*
      Two manifests live in /public so the same codebase can install as two distinct PWAs:
      - /manifest.webmanifest         → "TNext Cigars" (public editorial site)
      - /manifest-lounge.webmanifest  → "The Lounge"   (members app, /lounge/app/*)
      We pick which to advertise based on the current URL path so the home-screen icon name
      matches what the user is actually using.
    */}
    {Astro.url.pathname.startsWith("/lounge/app") ? (
      <>
        <link rel="manifest" href="/manifest-lounge.webmanifest" />
        <meta name="apple-mobile-web-app-title" content="The Lounge" />
        <meta name="application-name" content="The Lounge" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
      </>
    ) : (
      <>
        <link rel="manifest" href="/manifest.webmanifest" />
        <meta name="apple-mobile-web-app-title" content="TNext Cigars" />
        <meta name="application-name" content="TNext Cigars" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
      </>
    )}
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Impact.com publisher verification (proves we own thenextcigar.com) -->
    <meta name="impact-site-verification" content="25aa9188-d00c-497a-9b96-3ae2e4a285dd" />
    <!-- Partnerize / Ascend ownership verification token -->
    <meta name="partnerize-verification" content="Ascend Confirmation" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#ffffff" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={new URL(image, Astro.site).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Inter only (Cormorant Garamond removed in v4 Newsplate redesign) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <!-- Google AdSense — verification + ad serving once approved -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1364253563916945"
      crossorigin="anonymous"
    ></script>

    <!-- Snipcart cart (loads async, doesn't block render) -->
    <link rel="preconnect" href="https://app.snipcart.com" />
    <link rel="preconnect" href="https://cdn.snipcart.com" />
    <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.css" />

    <!-- MailerLite Universal loader (loads once per page; signup forms attach via <div class="ml-embedded">) -->
    <link rel="preconnect" href="https://assets.mailerlite.com" />
    <script is:inline>
      (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[]).push(arguments);},l=d.createElement(e),l.async=1,l.src=u,n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
      (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
      ml('account', '2332920');
    </script>

    {/* <ClientRouter /> — disabled, see frontmatter comment */}
  </head>
  <body class="min-h-screen bg-bg text-text antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-accent focus:text-bg focus:px-4 focus:py-2 focus:rounded">
      Skip to content
    </a>

    {!skipPublicChrome && <Header />}

    <main id="main">
      <slot />
    </main>

    {!skipPublicChrome && <Footer />}

    {/* SubscribeModal is for the public magazine only — Lounge has its own onboarding flow. */}
    {!isLoungeApp && <SubscribeModal />}
    <CookieBanner />

    {/* Travel sheet + FAB — only on Lounge app pages (excluding /travel itself, handled in component). */}
    {isLoungeApp && <TravelSheet />}

    <!-- Snipcart configuration (replace data-api-key with your real public key) -->
    <div
      hidden
      id="snipcart"
      data-api-key={import.meta.env.PUBLIC_SNIPCART_API_KEY || "YOUR_PUBLIC_API_KEY"}
      data-config-modal-style="side"
      data-currency="usd"
    ></div>
    <script async src="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.js"></script>

    <!-- Scroll-reveal -->
    <script is:inline>
      (function () {
        const setup = () => {
          const els = document.querySelectorAll(".reveal:not(.is-visible)");
          if (!("IntersectionObserver" in window) || window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            els.forEach((el) => el.classList.add("is-visible"));
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  io.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.1, rootMargin: "0px 0px -10% 0px" }
          );
          els.forEach((el) => io.observe(el));
        };
        document.addEventListener("astro:page-load", setup);
        setup();
      })();
    </script>

    <!-- Magnetic-button effect: any [data-magnetic] inside [data-magnetic-area] -->
    <script is:inline>
      (function () {
        const setup = () => {
          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
          if (window.matchMedia("(hover: none)").matches) return; // skip on touch
          const areas = document.querySelectorAll("[data-magnetic-area]");
          areas.forEach((area) => {
            if (area.dataset.magneticBound === "1") return;
            area.dataset.magneticBound = "1";
            const target = area.querySelector("[data-magnetic]");
            if (!target) return;
            area.addEventListener("mousemove", (e) => {
              const r = area.getBoundingClientRect();
              const x = ((e.clientX - r.left) / r.width - 0.5) * 14;
              const y = ((e.clientY - r.top) / r.height - 0.5) * 14;
              target.style.transform = `translate(${x}px, ${y}px)`;
            });
            area.addEventListener("mouseleave", () => {
              target.style.transform = "translate(0,0)";
            });
          });
        };
        document.addEventListener("astro:page-load", setup);
        setup();
      })();
    </script>

    <!-- Parallax fallback for browsers without scroll-driven animations -->
    <script is:inline>
      (function () {
        const setup = () => {
          if (CSS.supports("animation-timeline: scroll()")) return; // native handles it
          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
          const items = document.querySelectorAll("[data-parallax]");
          if (!items.length) return;
          let ticking = false;
          const update = () => {
            for (const el of items) {
              const r = el.getBoundingClientRect();
              const speed = parseFloat(el.dataset.parallaxSpeed || "0.18");
              const offset = (window.innerHeight - r.top) * speed;
              el.style.transform = `translateY(${-offset}px) scale(1.1)`;
            }
            ticking = false;
          };
          window.addEventListener("scroll", () => {
            if (!ticking) { ticking = true; requestAnimationFrame(update); }
          }, { passive: true });
          update();
        };
        document.addEventListener("astro:page-load", setup);
        setup();
      })();
    </script>
  </body>
</html>
