---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  noIndex?: boolean;
}

const {
  title = "The Next Cigar — Modern stories for the cigar aficionado",
  description = "A modern editorial home for cigar culture, history, gear, and the smoke that ties them together. Reviews, deep dives, and the news that matters.",
  image = "/og-default.svg",
  canonicalURL = new URL(Astro.url.pathname, Astro.site).toString(),
  noIndex = false,
} = Astro.props as Props;

const siteName = "The Next Cigar";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#151515" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={new URL(image, Astro.site).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Inter only (Cormorant Garamond removed in v4 Newsplate redesign) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <ClientRouter />
  </head>
  <body class="min-h-screen bg-bg text-text antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-accent focus:text-bg focus:px-4 focus:py-2 focus:rounded">
      Skip to content
    </a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <!-- Scroll-reveal -->
    <script is:inline>
      (function () {
        const setup = () => {
          const els = document.querySelectorAll(".reveal:not(.is-visible)");
          if (!("IntersectionObserver" in window) || window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            els.forEach((el) => el.classList.add("is-visible"));
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  io.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.1, rootMargin: "0px 0px -10% 0px" }
          );
          els.forEach((el) => io.observe(el));
        };
        document.addEventListener("astro:page-load", setup);
        setup();
      })();
    </script>

    <!-- Magnetic-button effect: any [data-magnetic] inside [data-magnetic-area] -->
    <script is:inline>
      (function () {
        const setup = () => {
          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
          if (window.matchMedia("(hover: none)").matches) return; // skip on touch
          const areas = document.querySelectorAll("[data-magnetic-area]");
          areas.forEach((area) => {
            if (area.dataset.magneticBound === "1") return;
            area.dataset.magneticBound = "1";
            const target = area.querySelector("[data-magnetic]");
            if (!target) return;
            area.addEventListener("mousemove", (e) => {
              const r = area.getBoundingClientRect();
              const x = ((e.clientX - r.left) / r.width - 0.5) * 14;
              const y = ((e.clientY - r.top) / r.height - 0.5) * 14;
              target.style.transform = `translate(${x}px, ${y}px)`;
            });
            area.addEventListener("mouseleave", () => {
              target.style.transform = "translate(0,0)";
            });
          });
        };
        document.addEventListener("astro:page-load", setup);
        setup();
      })();
    </script>

    <!-- Parallax fallback for browsers without scroll-driven animations -->
    <script is:inline>
      (function () {
        const setup = () => {
          if (CSS.supports("animation-timeline: scroll()")) return; // native handles it
          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
          const items = document.querySelectorAll("[data-parallax]");
          if (!items.length) return;
          let ticking = false;
          const update = () => {
            for (const el of items) {
              const r = el.getBoundingClientRect();
              const speed = parseFloat(el.dataset.parallaxSpeed || "0.18");
              const offset = (window.innerHeight - r.top) * speed;
              el.style.transform = `translateY(${-offset}px) scale(1.1)`;
            }
            ticking = false;
          };
          window.addEventListener("scroll", () => {
            if (!ticking) { ticking = true; requestAnimationFrame(update); }
          }, { passive: true });
          update();
        };
        document.addEventListener("astro:page-load", setup);
        setup();
      })();
    </script>
  </body>
</html>
