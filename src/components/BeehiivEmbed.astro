---
/**
 * NewsletterEmbed (filename kept as BeehiivEmbed.astro to avoid import
 * churn). Drops in the MailerLite signup form. The MailerLite Universal
 * loader is included in BaseLayout.astro so the script only fetches once
 * per page, even when multiple forms render (page form + SubscribeModal +
 * Footer Newsletter).
 *
 * To swap to a different MailerLite form, change FORM_HASH once here and
 * every signup spot on the site updates together.
 *
 * Migrated from Beehiiv → MailerLite on 2026-05-10. Custom sending domain
 * `contact@thenextcigar.com` is authenticated (DKIM + SPF + DMARC), so
 * welcome emails come from your own domain instead of `mail.beehiiv.com`.
 */

interface Props {
  /** Optional max width for the wrapper. Default 560px. */
  maxWidth?: string;
  /** Center the form horizontally inside its parent */
  center?: boolean;
}

const { maxWidth = "560px", center = false } = Astro.props;

// MailerLite form hash for "TheNextCigar Newsletter Signup"
// (visible in the form's embed code under the `data-form` attribute).
const FORM_HASH = "Xn19hv";
---

<div
  class:list={["newsletter-embed", center && "newsletter-embed--center"]}
  style={`max-width: ${maxWidth};`}
>
  <div class="ml-embedded" data-form={FORM_HASH}></div>
</div>

<style>
  .newsletter-embed {
    width: 100%;
  }
  .newsletter-embed--center {
    margin-left: auto;
    margin-right: auto;
  }
  /* MailerLite ships its own form styling. Keep it sitting flush in
     dark sections by giving the wrapper a subtle backing. */
  :global(.section-dark) .newsletter-embed {
    background: var(--color-bg);
    border-radius: 8px;
    padding: 0.5rem;
  }
</style>
