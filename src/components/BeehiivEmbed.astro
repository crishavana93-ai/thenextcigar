---
/**
 * BeehiivEmbed — drops in the Beehiiv subscribe form via their v3 loader.
 * The script tag is replaced in place with the rendered form once the
 * loader fetches the form definition from Beehiiv.
 *
 * To swap to a different Beehiiv form, change FORM_ID once here and
 * every signup spot on the site updates together.
 */

interface Props {
  /** Optional max width for the wrapper. Default 480px (Beehiiv's natural width). */
  maxWidth?: string;
  /** Center the form horizontally inside its parent */
  center?: boolean;
}

const { maxWidth = "480px", center = false } = Astro.props;

const FORM_ID = "8d78f521-7cc8-49f1-8315-1e9da6629415";
---

<div
  class:list={["beehiiv-embed", center && "beehiiv-embed--center"]}
  style={`max-width: ${maxWidth};`}
>
  <!--
    is:inline is critical here — without it Astro bundles this script,
    which breaks Beehiiv's loader handshake and leaves the form's parent
    wrapper stuck at height:0 (iframe loads but is invisible). Diagnosed
    2026-05-07 by inspecting the live DOM.
  -->
  <script async is:inline src="https://subscribe-forms.beehiiv.com/v3/loader.js" data-beehiiv-form={FORM_ID}></script>
</div>

<!--
  Defensive fallback shim. Beehiiv's loader wraps each form iframe in a div
  with `style="overflow:hidden;height:0;"` and waits for a postMessage from
  the iframe (`beehiiv:styles`) before revealing it. In some environments
  (bot-protection challenges, slow/blocked third-party scripts, etc.) that
  message never arrives and the form stays invisible despite loading
  correctly. After 7 seconds, force-reveal any stuck wrapper so the form is
  always usable.
-->
<script is:inline>
  (function () {
    function reveal() {
      var frames = document.querySelectorAll(
        'iframe[src*="subscribe-forms.beehiiv.com"]'
      );
      frames.forEach(function (f) {
        var p = f.parentElement;
        if (!p) return;
        var stuck =
          p.style.height === "0px" ||
          getComputedStyle(p).height === "0px";
        if (stuck) {
          p.style.height = "";
          p.style.overflow = "";
          // Beehiiv default form height — adjust to taste.
          if (!f.getAttribute("data-bhv-sized")) {
            f.style.height = "360px";
          }
        }
      });
    }
    // Run after 7s — gives Beehiiv's normal handshake first crack at it.
    setTimeout(reveal, 7000);
    // Also re-check on Astro client-side route changes.
    document.addEventListener("astro:page-load", function () {
      setTimeout(reveal, 7000);
    });
  })();
</script>

<style>
  .beehiiv-embed {
    width: 100%;
  }
  .beehiiv-embed--center {
    margin-left: auto;
    margin-right: auto;
  }
  /* Beehiiv's form ships with light styling. Make sure it sits nicely on
     dark sections by giving it a subtle backing */
  :global(.section-dark) .beehiiv-embed {
    background: var(--color-bg);
    border-radius: 8px;
    padding: 0.5rem;
  }
</style>
