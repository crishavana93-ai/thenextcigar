---
/**
 * Lounge app header — shown on every authenticated page under /lounge/app/.
 * Different from the public TNC header (Header.astro): minimal, member-focused,
 * with a logged-in nav bar.
 */
interface Props {
  active?: "dashboard" | "directory" | "map" | "travel" | "inbox" | "profile";
}
const { active = "dashboard" } = Astro.props as Props;
---

<header class="lounge-header">
  <div class="container-wide flex items-center justify-between py-4">
    <a href="/lounge/app/" class="lounge-header__brand" aria-label="TNext Cigar — The Lounge">
      <img src="/logo-light.png" alt="TNext Cigar" class="lounge-header__logo" />
      <span class="lounge-header__sub">The Lounge</span>
    </a>

    <nav class="lounge-header__nav" aria-label="Lounge sections">
      <a href="/lounge/app/" class:list={["lounge-nav-link", active === "dashboard" && "is-active"]}>Home</a>
      <a href="/lounge/app/directory/" class:list={["lounge-nav-link", active === "directory" && "is-active"]}>Members</a>
      <a href="/lounge/app/map/" class:list={["lounge-nav-link", active === "map" && "is-active"]}>Map</a>
      <a href="/lounge/app/travel/" class:list={["lounge-nav-link", active === "travel" && "is-active"]}>Travel</a>
      <a href="/lounge/app/inbox/" class:list={["lounge-nav-link", active === "inbox" && "is-active"]}>
        Inbox<span id="lounge-header-inbox-badge" class="lounge-header__badge" hidden>0</span>
      </a>
    </nav>

    <div class="lounge-header__user">
      <a href="/lounge/app/profile/" class:list={["lounge-nav-link lounge-header__name-link", active === "profile" && "is-active"]} aria-label="Edit profile">
        <span id="lounge-header-name">…</span>
      </a>

      {/* Hamburger replaces the standalone Sign Out button. Sign Out lives inside the dropdown. */}
      <button id="lounge-hamburger" class="lounge-hamburger" type="button"
        aria-label="Open menu" aria-haspopup="true" aria-expanded="false" aria-controls="lounge-menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="7" x2="21" y2="7" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="17" x2="21" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  {/* Dropdown menu (anchored under the hamburger).
      Kept intentionally small so the PWA stays isolated — no links out to the
      public magazine, which would bounce the user out of the installed app. */}
  <div id="lounge-menu" class="lounge-menu" hidden role="menu" aria-labelledby="lounge-hamburger">
    <a href="/lounge/app/profile/" class="lounge-menu__item" role="menuitem">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" />
      </svg>
      <span>Edit profile</span>
    </a>
    <a href="/lounge/app/events/" class="lounge-menu__item" role="menuitem">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" />
        <line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      <span>Events</span>
    </a>
    <a href="/lounge/app/places/" class="lounge-menu__item" role="menuitem">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      <span>Places</span>
    </a>
    {/* Admin link — hidden by default; the script below reveals it for admin emails only. */}
    <a href="/lounge/app/admin/" id="lounge-menu-admin" class="lounge-menu__item" role="menuitem" hidden>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
      </svg>
      <span>Admin</span>
    </a>
    {/* Install app — hidden by default. Revealed when the browser fires the
        beforeinstallprompt event (Chrome / Edge / Android), or shows iOS-specific
        instructions on iPhone Safari (which doesn't fire that event). */}
    <button id="lounge-menu-install" class="lounge-menu__item" role="menuitem" type="button" hidden>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" />
      </svg>
      <span>Install app</span>
      <span class="lounge-menu__hint" id="lounge-menu-install-hint">add to home screen</span>
    </button>
    <a href="https://thenextcigar.com/" class="lounge-menu__item" role="menuitem" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
        <polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" />
      </svg>
      <span>The magazine</span>
      <span class="lounge-menu__hint">opens browser</span>
    </a>
    <div class="lounge-menu__divider" role="separator"></div>
    <button id="lounge-signout" class="lounge-menu__item lounge-menu__item--destructive" type="button" role="menuitem">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
        <polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" />
      </svg>
      <span>Sign out</span>
    </button>
  </div>
</header>

<style>
  .lounge-header {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
    border-bottom: 1px solid var(--color-dark-border);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .lounge-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-on-dark);
    text-decoration: none;
  }
  .lounge-header__logo {
    height: 2.1rem;
    width: auto;
    display: block;
  }
  .lounge-header__sub {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    padding-left: 0.65rem;
    border-left: 1px solid rgba(255,255,255,0.18);
  }
  .lounge-header__nav {
    display: none;
    gap: 1.5rem;
  }
  /* Top nav shows on desktop only; on mobile/tablet the bottom tab bar takes over. */
  @media (min-width: 1024px) {
    .lounge-header__nav { display: flex; }
  }
  .lounge-nav-link {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-on-dark-mute);
    text-decoration: none;
    padding: 0.4rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .lounge-nav-link:hover {
    color: var(--color-text-on-dark);
  }
  .lounge-nav-link.is-active {
    color: var(--color-text-on-dark);
    border-bottom-color: var(--color-accent);
  }
  .lounge-header__user {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  /* On mobile/tablet the bottom tab bar already shows the member's name in the
     map / dashboard surfaces, so hide the redundant name in the header. */
  @media (max-width: 1023.98px) {
    .lounge-header__name-link { display: none; }
  }

  /* Hamburger button — replaces the standalone Sign Out CTA. */
  .lounge-hamburger {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: var(--color-text-on-dark);
    width: 40px;
    height: 40px;
    border-radius: 6px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .lounge-hamburger svg { width: 22px; height: 22px; display: block; }
  .lounge-hamburger:hover { border-color: var(--color-gold, #c9a961); }
  .lounge-hamburger[aria-expanded="true"] {
    background: rgba(201, 169, 97, 0.16);
    border-color: var(--color-gold, #c9a961);
    color: var(--color-gold, #c9a961);
  }

  /* Dropdown menu */
  .lounge-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 16px;
    min-width: 220px;
    background: var(--color-charcoal, #1a1d2e);
    border: 1px solid rgba(201, 169, 97, 0.28);
    border-radius: 8px;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.5);
    padding: 6px;
    z-index: 70;
    animation: menuIn 0.16s ease-out;
  }
  @media (min-width: 768px) {
    .lounge-menu { right: 24px; }
  }
  @keyframes menuIn {
    from { transform: translateY(-4px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .lounge-menu__item {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    padding: 10px 12px;
    background: transparent;
    border: none;
    color: var(--color-text-on-dark, #f3efe6);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    border-radius: 6px;
    text-align: left;
    font-family: inherit;
  }
  .lounge-menu__item svg { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.8; }
  .lounge-menu__item:hover {
    background: rgba(201, 169, 97, 0.1);
    color: var(--color-gold, #c9a961);
  }
  .lounge-menu__item:hover svg { opacity: 1; color: var(--color-gold, #c9a961); }
  .lounge-menu__item--destructive { color: rgba(255, 100, 100, 0.85); }
  .lounge-menu__item--destructive:hover { background: rgba(255, 46, 46, 0.12); color: #ff6b6b; }
  .lounge-menu__item--destructive:hover svg { color: #ff6b6b; }
  .lounge-menu__divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin: 4px 0;
  }
  .lounge-menu__hint {
    margin-left: auto;
    font-size: 10px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0;
    text-transform: lowercase;
  }
  .lounge-header__badge {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0;
    padding: 0.05rem 0.35rem;
    border-radius: 999px;
    margin-left: 0.4rem;
    min-width: 1rem;
    text-align: center;
    line-height: 1.3;
    vertical-align: middle;
  }
</style>

<script>
  import { getCurrentProfile, getCurrentUser, getSupabase, signOutAndRedirect } from "../../lib/supabase";

  async function setup() {
    const nameEl = document.getElementById("lounge-header-name");
    const profile = await getCurrentProfile();
    if (nameEl && profile) {
      nameEl.textContent = profile.display_name || "Member";
    }

    // Hamburger menu — opens dropdown with Sign Out + other menu items
    const hamburger = document.getElementById("lounge-hamburger") as HTMLButtonElement | null;
    const menu = document.getElementById("lounge-menu") as HTMLElement | null;
    if (hamburger && menu) {
      const openMenu = () => {
        menu.hidden = false;
        hamburger.setAttribute("aria-expanded", "true");
      };
      const closeMenu = () => {
        menu.hidden = true;
        hamburger.setAttribute("aria-expanded", "false");
      };
      hamburger.addEventListener("click", (e) => {
        e.stopPropagation();
        if (menu.hidden) openMenu();
        else closeMenu();
      });
      // Outside-click closes
      document.addEventListener("click", (e) => {
        if (!menu.hidden && !menu.contains(e.target as Node) && !hamburger.contains(e.target as Node)) {
          closeMenu();
        }
      });
      // Esc closes
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !menu.hidden) closeMenu();
      });
    }

    // Sign Out (now inside the menu)
    document.getElementById("lounge-signout")?.addEventListener("click", () => signOutAndRedirect());

    // Inbox pending count
    const badge = document.getElementById("lounge-header-inbox-badge");
    if (badge) {
      const user = await getCurrentUser();
      if (user) {
        const supabase = getSupabase();
        const { count } = await supabase
          .from("introductions")
          .select("id", { count: "exact", head: true })
          .eq("to_member_id", user.id)
          .is("accepted", null);
        if (count && count > 0) {
          badge.textContent = String(count);
          badge.hidden = false;
        }
      }
    }

    // Admin link — only show for founder emails
    const adminLink = document.getElementById("lounge-menu-admin");
    if (adminLink) {
      const user = await getCurrentUser();
      const ADMIN_EMAILS = ["guatabeycigars@gmail.com"];
      if (user && ADMIN_EMAILS.includes((user.email || "").toLowerCase())) {
        adminLink.hidden = false;
      }
    }

    // ── PWA install prompt ────────────────────────────────────────────────
    // Chrome / Edge / Android Chrome fire `beforeinstallprompt` when the page
    // is installable. We stash the event and reveal the menu item. On click,
    // we replay the saved prompt() — the browser then shows the install UI.
    //
    // iOS Safari does NOT fire this event (Apple's choice). For Safari we
    // detect the UA and show a small set of instructions instead.
    const installBtn = document.getElementById("lounge-menu-install") as HTMLButtonElement | null;
    const installHint = document.getElementById("lounge-menu-install-hint");
    if (installBtn) {
      // Already installed? Hide entirely.
      const standalone = window.matchMedia?.("(display-mode: standalone)").matches
        || (window.navigator as any).standalone === true;
      if (standalone) {
        installBtn.hidden = true;
      } else {
        let deferredPrompt: any = null;

        window.addEventListener("beforeinstallprompt", (e: any) => {
          e.preventDefault();
          deferredPrompt = e;
          installBtn.hidden = false;
        });

        // iOS Safari fallback — no event, just sniff and show iOS instructions.
        const ua = window.navigator.userAgent;
        const isIos = /iPhone|iPad|iPod/i.test(ua) && !/CriOS|FxiOS|EdgiOS/i.test(ua);
        if (isIos) {
          installBtn.hidden = false;
          if (installHint) installHint.textContent = "tap Share → Add to Home Screen";
        }

        installBtn.addEventListener("click", async () => {
          if (deferredPrompt) {
            deferredPrompt.prompt();
            const { outcome } = await deferredPrompt.userChoice;
            if (outcome === "accepted") {
              installBtn.hidden = true;
            }
            deferredPrompt = null;
          } else if (isIos) {
            alert(
              "To install: tap the Share button (square + arrow) at the bottom of Safari, then 'Add to Home Screen'."
            );
          } else {
            alert(
              "Open this page in Chrome or Edge on a phone/laptop to install it as an app."
            );
          }
        });

        // If install completes outside our flow (e.g. via the URL bar prompt),
        // hide the button.
        window.addEventListener("appinstalled", () => {
          installBtn.hidden = true;
        });
      }
    }
  }
  document.addEventListener("astro:page-load", setup);
  setup();
</script>
