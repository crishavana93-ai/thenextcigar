---
interface Props { class?: string; }
const { class: className = "w-8 h-8" } = Astro.props;
---

<!-- Mark: stylized cigar with ember tip — small enough to feel like a wordmark glyph -->
<svg class={className} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <linearGradient id="band" x1="0" x2="1">
      <stop offset="0" stop-color="#c9a961" />
      <stop offset="1" stop-color="#b08243" />
    </linearGradient>
    <radialGradient id="ember" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0" stop-color="#ffd479" />
      <stop offset="0.6" stop-color="#d97757" />
      <stop offset="1" stop-color="#5a1a0a" />
    </radialGradient>
  </defs>
  <!-- Cigar body -->
  <rect x="3" y="13" width="22" height="6" rx="2" fill="#3a2a1c" stroke="#241710" stroke-width="0.5" />
  <!-- Aged wrapper sheen -->
  <rect x="3" y="13" width="22" height="2" rx="1" fill="#5a3f29" opacity="0.7" />
  <!-- Band -->
  <rect x="9" y="13" width="6" height="6" fill="url(#band)" />
  <line x1="9" y1="13" x2="9" y2="19" stroke="#241710" stroke-width="0.4" />
  <line x1="15" y1="13" x2="15" y2="19" stroke="#241710" stroke-width="0.4" />
  <!-- Ember tip -->
  <circle cx="27" cy="16" r="3" fill="url(#ember)" />
  <!-- Smoke wisp -->
  <path d="M28 13 C 29 11, 27 10, 28.5 8 C 30 6, 28.5 4, 30 2"
        stroke="#a89986" stroke-width="0.6" stroke-linecap="round" fill="none" opacity="0.55" />
</svg>
