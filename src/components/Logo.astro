---
interface Props {
  /** "wordmark" = full TNext Cigar logo, "mark" = compact smoke-wisp glyph */
  variant?: "wordmark" | "mark";
  class?: string;
}

const { variant = "mark", class: className = "" } = Astro.props;

// Import the SVG inline so it inherits currentColor and can be styled
const logoUrl = variant === "wordmark" ? "/logo.svg" : "/logo-mark.svg";
---

{variant === "wordmark" ? (
  <img
    src={logoUrl}
    alt="TNext Cigar"
    class={className}
    width="800"
    height="320"
    style="color: currentColor;"
  />
) : (
  <svg viewBox="0 0 64 64" fill="none" class={className} aria-label="TNext Cigar">
    <line x1="6" y1="32" x2="22" y2="32" stroke="currentColor" stroke-width="1.5" />
    <path
      d="M27 18 c -3 5, 5 8, 0 14 c -5 6, 5 8, 0 14"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      fill="none"
    />
    <line x1="42" y1="32" x2="58" y2="32" stroke="currentColor" stroke-width="1.5" />
  </svg>
)}
