---
/**
 * SocialIcons — render available social channels.
 * Add accounts as you create them by setting the URL constants below.
 */

interface Props {
  size?: "sm" | "md";
  variant?: "light" | "dark"; // dark = white icons on dark bg, light = dark icons on light bg
}

const { size = "md", variant = "dark" } = Astro.props;

// Update these as social accounts are created.
const socials = [
  { name: "Instagram", url: "https://instagram.com/thenextcigar", visible: true },
  { name: "YouTube", url: "https://youtube.com/@thenextcigar", visible: true },
  { name: "X / Twitter", url: "https://x.com/thenextcigar", visible: true },
  { name: "Facebook", url: "https://facebook.com/thenextcigar", visible: false },
  { name: "TikTok", url: "https://tiktok.com/@thenextcigar", visible: false },
  { name: "LinkedIn", url: "https://linkedin.com/company/thenextcigar", visible: false },
];

const iconSize = size === "sm" ? 16 : 18;
const containerSize = size === "sm" ? "w-8 h-8" : "w-10 h-10";
---

<div class:list={["flex items-center gap-2", variant === "dark" ? "text-[color:var(--color-text-on-dark-soft)]" : "text-[color:var(--color-text-soft)]"]}>
  {socials.filter((s) => s.visible).map((s) => (
    <a
      href={s.url}
      target="_blank"
      rel="noopener noreferrer me"
      aria-label={s.name}
      class:list={[
        "rounded-full flex items-center justify-center transition-colors",
        containerSize,
        variant === "dark"
          ? "border border-[color:var(--color-dark-border)] hover:text-[color:var(--color-accent)] hover:border-[color:var(--color-accent)]"
          : "border border-[color:var(--color-border)] hover:text-[color:var(--color-accent)] hover:border-[color:var(--color-accent)]"
      ]}
    >
      {s.name === "Instagram" && (
        <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      )}
      {s.name === "YouTube" && (
        <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor"><path d="M21.582 7.001a2.506 2.506 0 0 0-1.768-1.768C18.254 4.81 12 4.81 12 4.81s-6.254 0-7.814.423a2.506 2.506 0 0 0-1.768 1.768C2 8.561 2 12 2 12s0 3.439.418 4.999a2.506 2.506 0 0 0 1.768 1.768C5.746 19.19 12 19.19 12 19.19s6.254 0 7.814-.423a2.506 2.506 0 0 0 1.768-1.768C22 15.439 22 12 22 12s0-3.439-.418-4.999zM10 15V9l5.196 3z"/></svg>
      )}
      {s.name === "X / Twitter" && (
        <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      )}
      {s.name === "Facebook" && (
        <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      )}
      {s.name === "TikTok" && (
        <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.83 20.1a6.34 6.34 0 0 0 10.86-4.43V8.94a8.16 8.16 0 0 0 4.77 1.52V7.05a4.85 4.85 0 0 1-1.87-.36z"/></svg>
      )}
      {s.name === "LinkedIn" && (
        <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452z"/></svg>
      )}
    </a>
  ))}
</div>
