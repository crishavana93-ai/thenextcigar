---
/**
 * AdSlot — placeholder for display ad networks.
 *
 * Drop this anywhere you want to reserve space for a banner. By default it
 * renders a labeled "Sponsored" placeholder, so you can see placement during
 * design. When you sign up with a network (Ezoic / Mediavine / Raptive /
 * AdSense), replace the inner block with their ad code.
 *
 * Variants: leaderboard (728/970x90), billboard (970x250), medium (300x250),
 * in-article (responsive 600x250+), halfpage (300x600).
 *
 * Pass `network="ezoic"` (etc.) once wired so the same component can branch.
 */

interface Props {
  variant?: "leaderboard" | "billboard" | "medium" | "in-article" | "halfpage";
  label?: string;
  className?: string;
  /** Set to true to hide the slot in production until a network is wired. */
  hidden?: boolean;
}

const { variant = "leaderboard", label, className, hidden = false } = Astro.props;
const sizeMap: Record<string, string> = {
  leaderboard: "728 × 90 / 970 × 90",
  billboard: "970 × 250",
  medium: "300 × 250",
  "in-article": "responsive — In-Article",
  halfpage: "300 × 600",
};
---

{!hidden && (
  <aside
    class:list={["ad-slot", `ad-slot--${variant}`, "ad-slot--house", className]}
    role="complementary"
    aria-label="Newsletter signup"
  >
    {/*
      House-ad fallback: shown while no third-party ad network is wired.
      Converts otherwise-empty inventory into newsletter signups. Once
      AdSense / Ezoic / Mediavine is approved and live, replace this
      block with their <script>+<ins> snippet — the surrounding <aside>
      dimensions stay so layout doesn't shift.
    */}
    <a href="/subscribe" class="ad-slot__house" data-variant={variant}>
      <div class="ad-slot__house-eyebrow">The Next Cigar · Sunday newsletter</div>
      <div class="ad-slot__house-title">Cigar news, deep dives, and the rare smokes worth tracking down.</div>
      <div class="ad-slot__house-cta">Join free →</div>
    </a>
  </aside>
)}

<style>
  .ad-slot--house {
    display: block;
    margin: 0 auto;
    max-width: 100%;
  }
  .ad-slot__house {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 0.4rem;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, var(--color-dark) 0%, #1f1f1f 100%);
    color: var(--color-text-on-dark);
    text-decoration: none;
    border-radius: 6px;
    border: 1px solid var(--color-dark-border);
    transition: border-color 200ms, transform 200ms;
    min-height: 90px;
  }
  .ad-slot__house:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .ad-slot__house-eyebrow {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    font-weight: 700;
  }
  .ad-slot__house-title {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-text-on-dark);
    max-width: 60ch;
  }
  .ad-slot__house-cta {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: 0.25rem;
  }
  .ad-slot__house[data-variant="leaderboard"] { min-height: 90px; }
  .ad-slot__house[data-variant="billboard"] { min-height: 250px; }
  .ad-slot__house[data-variant="medium"] { min-height: 250px; max-width: 300px; }
  .ad-slot__house[data-variant="halfpage"] { min-height: 480px; max-width: 300px; }
  .ad-slot__house[data-variant="in-article"] { min-height: 200px; }
</style>
