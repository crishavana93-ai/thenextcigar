---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  featured: CollectionEntry<"blog">;
  side: CollectionEntry<"blog">[];
  categoryByslug: Map<string, { name: string; slug: string }>;
}

const { featured, side, categoryByslug } = Astro.props;
const fc = featured.data.category ? categoryByslug.get(featured.data.category) : null;

const fmtDate = (d: Date | string) =>
  new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

// Newsplate-style long-form date used in the featured hero (e.g. "Monday, January 29, 2026")
const fmtLongDate = (d: Date | string) =>
  new Date(d).toLocaleDateString("en-US", {
    weekday: "long",
    month: "long",
    day: "numeric",
    year: "numeric",
  }).toUpperCase();
---

<section class="container-wide pt-10 pb-20">
  <div class="flex items-center justify-between mb-8 reveal">
    <p class="section-eyebrow">Highlight News</p>
    <a href="/blog" class="text-sm text-[color:var(--color-text-muted)] hover:text-[color:var(--color-accent)] transition-colors uppercase tracking-wider">
      View all →
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
    {/* FEATURED — large left, spans 2 cols.
        v5 mobile-first hero (May 2026):
        - aspect 4:5 portrait on mobile (taller -> headline has vertical room)
          16:10 tablet, 16:9 cinematic on desktop.
        - dark charcoal scrim from bottom (fade-to-cream from previous version
          made black text unreadable over busy product photos).
        - white headline guaranteed readable. Cream-deep on hover.
        - category tag stays accent red; date stays light-on-dark.
        - subtle text-shadow on the title as a belt-and-braces fallback. */}
    <a href={`/blog/${featured.data.slug}`} class="lg:col-span-2 group reveal" aria-label={featured.data.title}>
      <div class="relative overflow-hidden rounded aspect-[4/5] sm:aspect-[16/10] lg:aspect-[16/9] bg-[color:var(--color-dark)]">
        {featured.data.cover && (typeof featured.data.cover === "string" ? (
          <img
            src={featured.data.cover}
            alt={featured.data.title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 animate-drift"
            loading="eager"
          />
        ) : (
          <Image
            src={featured.data.cover}
            alt={featured.data.title}
            widths={[600, 900, 1200, 1800]}
            sizes="(min-width: 1024px) 66vw, 100vw"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 animate-drift"
            loading="eager"
          />
        ))}
        {/* Dark scrim — taller on mobile (image+title fit a phone screen),
            tighter on desktop. Charcoal var(--color-dark) base. */}
        <div class="hero-scrim absolute inset-0 pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 right-0 p-5 md:p-8 lg:p-12">
          {/* Newsplate-style metadata bar — date + category above the title */}
          <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mb-3 md:mb-4 text-[0.62rem] md:text-xs uppercase tracking-[0.18em] font-bold text-[color:var(--color-text-on-dark-soft)]">
            <span class="inline-flex items-center gap-2">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              {fmtLongDate(featured.data.publishedAt)}
            </span>
            {fc && (
              <span class="inline-flex items-center gap-2 text-[color:var(--color-accent)]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                  <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
                {fc.name}
              </span>
            )}
          </div>
          <h2 class="hero-title font-display text-[1.75rem] md:text-5xl lg:text-6xl leading-[1.05] md:leading-[1.02] tracking-tight font-extrabold text-[color:var(--color-text-on-dark)] group-hover:text-[color:var(--color-headline-hover-on-dark)] transition-colors duration-300 max-w-4xl">
            {featured.data.title}
          </h2>
          {featured.data.excerpt && (
            <p class="hidden sm:block mt-4 md:mt-5 text-[color:var(--color-text-on-dark-soft)] line-clamp-2 max-w-2xl text-sm md:text-base leading-relaxed">
              {featured.data.excerpt}
            </p>
          )}
        </div>
      </div>
    </a>

    {/* SIDE — 2 stacked stories */}
    <div class="flex flex-col gap-6 lg:gap-8">
      {side.slice(0, 2).map((p, i) => {
        const c = p.data.category ? categoryByslug.get(p.data.category) : null;
        return (
          <a href={`/blog/${p.data.slug}`} class="reveal group flex-1" data-reveal-delay={(i + 1) as 1 | 2}>
            <div class="relative overflow-hidden rounded aspect-[16/10] lg:aspect-[16/9] mb-4 bg-[color:var(--color-surface)]">
              {p.data.cover && (typeof p.data.cover === "string" ? (
                <img
                  src={p.data.cover}
                  alt={p.data.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="eager"
                />
              ) : (
                <Image
                  src={p.data.cover}
                  alt={p.data.title}
                  widths={[400, 800]}
                  sizes="(min-width: 1024px) 33vw, 100vw"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="eager"
                />
              ))}
            </div>
            {c && <p class="category-tag mb-2">{c.name}</p>}
            <h3 class="font-display text-lg md:text-xl leading-tight text-[color:var(--color-text)] group-hover:text-[color:var(--color-headline-hover-on-light)] transition-colors duration-300">
              {p.data.title}
            </h3>
            <p class="mt-2 text-xs text-[color:var(--color-text-muted)] uppercase tracking-wider">
              {fmtDate(p.data.publishedAt)}
            </p>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* Hero scrim — three-stop dark gradient. Charcoal at the bottom where
     the headline sits, gradually transparent toward the top so the image
     reads. Mobile gets a taller dark band because the portrait crop puts
     more of the image area underneath the headline block. */
  .hero-scrim {
    background-image: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-dark) 92%, transparent) 0%,
      color-mix(in srgb, var(--color-dark) 78%, transparent) 28%,
      color-mix(in srgb, var(--color-dark) 35%, transparent) 55%,
      transparent 80%
    );
  }

  @media (min-width: 1024px) {
    .hero-scrim {
      background-image: linear-gradient(
        to top,
        color-mix(in srgb, var(--color-dark) 90%, transparent) 0%,
        color-mix(in srgb, var(--color-dark) 60%, transparent) 38%,
        transparent 70%
      );
    }
  }

  /* Headline safety net — text-shadow keeps the title legible even if a
     particular cover image happens to be mostly black in the title band
     (rare with the scrim already in place, but cheap insurance). */
  .hero-title {
    text-shadow: 0 1px 24px rgba(0, 0, 0, 0.45), 0 2px 4px rgba(0, 0, 0, 0.35);
  }
</style>
