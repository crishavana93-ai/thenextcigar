---
import BeehiivEmbed from "./BeehiivEmbed.astro";

interface Props {
  variant?: "inline" | "hero";
  heading?: string;
  blurb?: string;
}
const {
  variant = "inline",
  heading = "Stories worth lighting up",
  blurb = "A weekly dispatch on cigar culture, news, and the rare smokes worth tracking down. Two minutes, one good cigar to add to your list.",
} = Astro.props;
---

<section
  class:list={[
    variant === "hero" ? "py-24" : "py-20",
    "border-y border-[color:var(--color-border)] bg-[color:var(--color-bg-soft)]",
  ]}
>
  <div class="container-narrow text-center reveal">
    <p class="eyebrow justify-center mb-3">Newsletter</p>
    <h2 class="font-display text-3xl md:text-5xl leading-tight max-w-2xl mx-auto">
      {heading}
    </h2>
    <p class="lead mt-5 max-w-xl mx-auto">{blurb}</p>

    <div class="mt-10 flex justify-center">
      <BeehiivEmbed center maxWidth="520px" />
    </div>

    <p class="mt-4 text-xs text-[color:var(--color-text-muted)]">
      No spam. Unsubscribe with a click. We don't sell your data.
    </p>
  </div>
</section>
