---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  categoryName?: string;
  size?: "sm" | "md" | "lg";
  delay?: 1 | 2 | 3 | 4;
}

const { post, categoryName, size = "md", delay } = Astro.props;
const data = post.data;

const date = new Date(data.publishedAt).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const titleClass = size === "lg"
  ? "text-3xl md:text-4xl"
  : size === "sm"
  ? "text-base"
  : "text-xl md:text-2xl";

const cover = data.cover ?? data.thumbnail;
---

<a
  href={`/blog/${data.slug}`}
  class="card reveal block group"
  data-reveal-delay={delay}
  aria-label={data.title}
>
  {cover && (
    <div class="card-image">
      <Image
        src={cover}
        alt={data.title}
        widths={[400, 800, 1200]}
        sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        loading="lazy"
      />
      {data.isPremium && (
        <span class="absolute top-3 left-3 px-2 py-1 text-[0.65rem] font-semibold tracking-widest uppercase bg-[color:var(--color-accent)] text-[color:var(--color-bg)] rounded-sm">
          Premium
        </span>
      )}
    </div>
  )}
  <div class="p-6">
    {categoryName && (
      <p class="eyebrow mb-3">{categoryName}</p>
    )}
    <h3 class:list={["font-display leading-tight text-[color:var(--color-text)] group-hover:text-[color:var(--color-accent)] transition-colors", titleClass]}>
      {data.title}
    </h3>
    {size !== "sm" && data.excerpt && (
      <p class="mt-3 text-[color:var(--color-muted)] line-clamp-3 text-sm leading-relaxed">
        {data.excerpt}
      </p>
    )}
    <p class="mt-4 text-xs text-[color:var(--color-muted-2)] tracking-wider uppercase">{date}</p>
  </div>
</a>
