---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  categoryName?: string;
  size?: "sm" | "md" | "lg" | "xl";
  delay?: 1 | 2 | 3 | 4;
  horizontal?: boolean;
  noImage?: boolean;
}

const { post, categoryName, size = "md", delay, horizontal = false, noImage = false } = Astro.props;
const data = post.data;

const date = new Date(data.publishedAt).toLocaleDateString("en-US", {
  year: "numeric", month: "short", day: "numeric",
});

const titleSize =
  size === "xl" ? "text-3xl md:text-5xl" :
  size === "lg" ? "text-2xl md:text-3xl" :
  size === "sm" ? "text-base md:text-lg" :
  "text-xl md:text-2xl";

const cover = data.cover ?? data.thumbnail;
---

<a
  href={`/blog/${data.slug}/`}
  class:list={[
    "card reveal block group",
    horizontal && "flex flex-row gap-4 items-start",
  ]}
  data-reveal-delay={delay}
  aria-label={data.title}
>
  {!noImage && cover && (
    <div class:list={["card-image", horizontal && "w-32 h-24 flex-shrink-0 aspect-square"]}>
      <Image
        src={cover}
        alt={data.title}
        widths={[400, 800, 1200]}
        sizes={horizontal ? "120px" : "(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"}
        loading="lazy"
      />
      {data.isPremium && (
        <span class="absolute top-3 left-3 px-2.5 py-1.5 text-[0.62rem] font-bold tracking-widest uppercase bg-[color:var(--color-dark)] text-white rounded-sm flex items-center gap-1.5">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Member only
        </span>
      )}
    </div>
  )}
  <div class:list={["card-body", horizontal && "flex-1 min-w-0 !pt-0"]}>
    {categoryName && (
      <p class="category-tag mb-2">{categoryName}</p>
    )}
    <h3 class:list={["card-title", titleSize]}>
      {data.title}
    </h3>
    {size !== "sm" && !horizontal && data.excerpt && (
      <p class="mt-3 text-[color:var(--color-text-muted)] line-clamp-2 text-sm leading-relaxed">
        {data.excerpt}
      </p>
    )}
    <p class="card-meta uppercase">{date}</p>
  </div>
</a>
