---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/ProductCard.astro";
import Newsletter from "../../components/Newsletter.astro";

export async function getStaticPaths() {
  const products = (await getCollection("products")).filter((p) => !p.data.isArchived);
  return products.map((product) => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const data = product.data;

const fmtPrice = (n: number) =>
  new Intl.NumberFormat("en-US", { style: "currency", currency: data.currency }).format(n);

const isOnSale = data.compareAtPrice && data.compareAtPrice > data.price;

// Related products (same type, excluding this one)
const allProducts = await getCollection("products");
const related = allProducts
  .filter((p) => p.id !== product.id && !p.data.isArchived && p.data.type === data.type)
  .slice(0, 3);

// The site's canonical URL for the product (used by Snipcart's data-item-url)
const productUrl = `https://thenextcigar.com/shop/${data.slug}/`;

// Convert variants to Snipcart custom-fields markup
const variantAttrs = (data.variants || []).map((v, i) => {
  const num = i + 1;
  return {
    name: `data-item-custom${num}-name`,
    value: v.name,
    options: `data-item-custom${num}-options`,
    optionsValue: v.options.join("|"),
  };
});
---

<BaseLayout
  title={data.seo?.metaTitle || `${data.name} — TNext Cigar Shop`}
  description={data.seo?.metaDescription || data.excerpt || data.name}
  image={typeof data.cover === "string" ? data.cover : data.cover.src}
>
  <article class="container-wide pt-12 md:pt-20 pb-24">
    <nav class="mb-8 text-xs tracking-widest uppercase text-[color:var(--color-text-muted)]" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[color:var(--color-accent)] transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/shop/" class="hover:text-[color:var(--color-accent)] transition-colors">Shop</a>
      <span class="mx-2">/</span>
      <span class="text-[color:var(--color-text)]">{data.name}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      {/* GALLERY */}
      <div class="reveal">
        <div class="rounded-sm overflow-hidden bg-[color:var(--color-surface)] aspect-square">
          {typeof data.cover === "string" ? (
            <img src={data.cover} alt={data.name} class="w-full h-full object-cover" loading="eager" />
          ) : (
            <Image
              src={data.cover}
              alt={data.name}
              widths={[600, 1200]}
              sizes="(min-width: 1024px) 50vw, 100vw"
              class="w-full h-full object-cover"
              loading="eager"
            />
          )}
        </div>
        {data.gallery && data.gallery.length > 1 && (
          <div class="mt-3 grid grid-cols-4 gap-3">
            {data.gallery.map((img, i) => (
              <div class="rounded-sm overflow-hidden bg-[color:var(--color-surface)] aspect-square">
                {typeof img === "string" ? (
                  <img src={img} alt={`${data.name} — view ${i + 1}`} class="w-full h-full object-cover" loading="lazy" />
                ) : (
                  <Image src={img} alt={`${data.name} — view ${i + 1}`} widths={[200, 400]} sizes="120px" class="w-full h-full object-cover" loading="lazy" />
                )}
              </div>
            ))}
          </div>
        )}
      </div>

      {/* DETAILS */}
      <div class="reveal" data-reveal-delay="1">
        <p class="text-xs uppercase tracking-widest text-[color:var(--color-text-muted)] mb-3">
          {data.type === "digital" ? "Digital · Instant download" : data.type === "merch" ? "Branded merch · Made on order" : "Accessory · Drop-ship from US"}
        </p>
        <h1 class="font-display text-3xl md:text-5xl leading-[1.1] tracking-tight">{data.name}</h1>

        {data.excerpt && (
          <p class="lead mt-6">{data.excerpt}</p>
        )}

        <div class="mt-8 flex items-baseline gap-4">
          <span class="font-display text-3xl font-bold text-[color:var(--color-text)]">{fmtPrice(data.price)}</span>
          {isOnSale && (
            <span class="text-lg text-[color:var(--color-text-mute-2)] line-through">{fmtPrice(data.compareAtPrice!)}</span>
          )}
          {isOnSale && (
            <span class="px-2 py-0.5 text-[0.65rem] font-bold tracking-widest uppercase bg-[color:var(--color-accent)] text-white rounded-sm">
              {Math.round(((data.compareAtPrice! - data.price) / data.compareAtPrice!) * 100)}% off
            </span>
          )}
        </div>

        {/* SNIPCART BUTTON */}
        <div class="mt-8">
          <button
            type="button"
            class="snipcart-add-item btn btn-primary !px-8 !py-4 text-base"
            data-item-id={data.sku}
            data-item-price={data.price}
            data-item-url={productUrl}
            data-item-name={data.name}
            data-item-image={typeof data.cover === "string" ? data.cover : data.cover.src}
            data-item-description={data.excerpt || ""}
            data-item-shippable={String(data.requiresShipping)}
            data-item-weight={data.weight ?? ""}
            data-item-categories={data.category || ""}
            {...variantAttrs.reduce((acc, v) => ({ ...acc, [v.name]: v.value, [v.options]: v.optionsValue }), {})}
            disabled={!data.inStock}
          >
            {data.inStock ? "Add to cart" : "Sold out"}
          </button>
          <a href="#" class="snipcart-checkout ml-3 text-sm text-[color:var(--color-text-muted)] hover:text-[color:var(--color-accent)] transition-colors uppercase tracking-wider">
            View cart →
          </a>
        </div>

        <div class="mt-6 text-xs text-[color:var(--color-text-muted)] space-y-1">
          {data.type === "digital" && (
            <p>✓ Instant download · DRM-free PDF · Yours forever</p>
          )}
          {data.type !== "digital" && data.requiresShipping && (
            <>
              <p>✓ Ships within 1–3 business days</p>
              <p>✓ 30-day return window on unused items</p>
            </>
          )}
          <p>✓ Secure checkout via Stripe (Snipcart)</p>
        </div>

        {/* DESCRIPTION */}
        <div class="prose mt-12 max-w-none">
          <Content />
        </div>

        {/* TRUST FOOTER */}
        <div class="hairline my-10"></div>
        <p class="text-xs text-[color:var(--color-text-muted)] leading-relaxed">
          <strong class="text-[color:var(--color-text)]">We don't sell tobacco.</strong> TNext Cigar is a publication. The shop carries non-tobacco accessories, branded merch, and digital products only. For cigars, see our retailer affiliates linked from individual articles.
        </p>
      </div>
    </div>
  </article>

  {related.length > 0 && (
    <section class="py-16 bg-[color:var(--color-bg-soft)] border-t border-[color:var(--color-border)]">
      <div class="container-wide">
        <p class="text-xs uppercase tracking-widest text-[color:var(--color-text-muted)] mb-2">More like this</p>
        <h2 class="section-eyebrow mb-12">Related</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
          {related.map((p, i) => (
            <ProductCard product={p} delay={((i % 3) + 1) as 1 | 2 | 3} />
          ))}
        </div>
      </div>
    </section>
  )}

  <Newsletter />
</BaseLayout>
