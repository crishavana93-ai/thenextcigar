---
import BaseLayout from "../layouts/BaseLayout.astro";
import BeehiivEmbed from "../components/BeehiivEmbed.astro";
---

<BaseLayout
  title="Subscribe — TNext Cigar"
  description="Join the weekly dispatch. One good email, every Sunday."
>
  <section class="container-narrow pt-24 pb-32 text-center">
    <p class="eyebrow justify-center mb-4 reveal">Newsletter</p>
    <h1 class="font-display text-5xl md:text-7xl leading-tight reveal">One good email,<br/>every Sunday.</h1>
    <p class="lead mt-8 max-w-xl mx-auto reveal">
      Cigar news, deep dives, and the rare smokes worth tracking down — written by people who actually light them. Two minutes to read. No spam, ever. Free.
    </p>

    <div class="mt-12 flex justify-center reveal">
      <BeehiivEmbed center maxWidth="560px" />
    </div>

    <p class="mt-4 text-xs text-[color:var(--color-text-muted)]">
      For 21+ adults. We never sell or share your email.
    </p>

    <div class="hairline my-20"></div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-left">
      <div class="reveal" data-reveal-delay="1">
        <p class="eyebrow mb-2">Weekly</p>
        <h3 class="font-display text-xl mb-3">Sunday only</h3>
        <p class="text-[color:var(--color-text-muted)] text-sm leading-relaxed">One email per week. Sundays. Nothing else hits your inbox.</p>
      </div>
      <div class="reveal" data-reveal-delay="2">
        <p class="eyebrow mb-2">Curated</p>
        <h3 class="font-display text-xl mb-3">5 things</h3>
        <p class="text-[color:var(--color-text-muted)] text-sm leading-relaxed">A featured story, two news beats, one cigar to try, and one thing worth your travel.</p>
      </div>
      <div class="reveal" data-reveal-delay="3">
        <p class="eyebrow mb-2">Free</p>
        <h3 class="font-display text-xl mb-3">No paywall</h3>
        <p class="text-[color:var(--color-text-muted)] text-sm leading-relaxed">A premium tier is on the way. The free dispatch will always stay free.</p>
      </div>
    </div>
  </section>
</BaseLayout>
