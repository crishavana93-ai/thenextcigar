---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact — TNext Cigar"
  description="Get in touch with the editorial team."
>
  <section class="container-prose pt-20 md:pt-32 pb-24">
    <p class="eyebrow mb-4 reveal">Contact</p>
    <h1 class="font-display text-5xl md:text-7xl leading-tight reveal">Reach out.</h1>
    <p class="lead mt-8 reveal">
      Story tips, brand pitches, sponsorship inquiries, partnership ideas, corrections, or just to say hello — the inbox is open.
    </p>

    <div class="hairline my-16"></div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div class="reveal">
        <p class="eyebrow mb-3">Editorial</p>
        <h3 class="font-display text-2xl mb-3">Story tips & corrections</h3>
        <p class="text-[color:var(--color-text-muted)] leading-relaxed mb-4">
          Got a tip on an upcoming release, a factory you want covered, an event we should send someone to? We read every tip.
        </p>
        <a href="mailto:contact@thenextcigar.com" class="text-[color:var(--color-accent)] hover:underline font-semibold">
          contact@thenextcigar.com
        </a>
      </div>
      <div class="reveal" data-reveal-delay="1">
        <p class="eyebrow mb-3">Business</p>
        <h3 class="font-display text-2xl mb-3">Sponsorships & partnerships</h3>
        <p class="text-[color:var(--color-text-muted)] leading-relaxed mb-4">
          Brand collaborations, newsletter sponsorships, sponsored review slots, retail partnerships, and direct ad placements.
        </p>
        <a href="mailto:contact@thenextcigar.com" class="text-[color:var(--color-accent)] hover:underline font-semibold">
          contact@thenextcigar.com
        </a>
      </div>
    </div>

    <div class="hairline my-16"></div>

    {/*
      Form handler: Formsubmit.co — no signup, no API key required.
      Submissions POST to formsubmit.co and are forwarded to the email below.
      First submission triggers a one-time verification email — click the
      "Confirm your email" link inside, then all subsequent submissions
      route directly to the inbox. Replace the email in the action URL if
      you ever change your inbox.
    */}
    <form
      id="contact-form"
      class="reveal"
      action="https://formsubmit.co/guatabeycigars@gmail.com"
      method="POST"
    >
      <p class="eyebrow mb-3">Or send us a note</p>
      <h3 class="font-display text-2xl mb-6">General inquiries</h3>

      {/* Formsubmit config — hidden fields */}
      <input type="hidden" name="_subject" value="New message from thenextcigar.com" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="true" />
      <input type="hidden" name="_next" value="https://thenextcigar.com/contact/?sent=1" />
      <input type="hidden" name="_honey" value="" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label for="contact-name" class="block text-xs uppercase tracking-widest text-[color:var(--color-text-muted)] mb-2">Name</label>
          <input id="contact-name" name="name" type="text" required class="w-full bg-[color:var(--color-bg-soft)] border border-[color:var(--color-border)] rounded px-4 py-3 text-[color:var(--color-text)] focus:outline-none focus:border-[color:var(--color-accent)] transition-colors" />
        </div>
        <div>
          <label for="contact-email" class="block text-xs uppercase tracking-widest text-[color:var(--color-text-muted)] mb-2">Email</label>
          <input id="contact-email" name="email" type="email" required class="w-full bg-[color:var(--color-bg-soft)] border border-[color:var(--color-border)] rounded px-4 py-3 text-[color:var(--color-text)] focus:outline-none focus:border-[color:var(--color-accent)] transition-colors" />
        </div>
      </div>

      <div class="mb-4">
        <label for="contact-subject" class="block text-xs uppercase tracking-widest text-[color:var(--color-text-muted)] mb-2">Subject</label>
        <input id="contact-subject" name="subject" type="text" required class="w-full bg-[color:var(--color-bg-soft)] border border-[color:var(--color-border)] rounded px-4 py-3 text-[color:var(--color-text)] focus:outline-none focus:border-[color:var(--color-accent)] transition-colors" />
      </div>

      <div class="mb-6">
        <label for="contact-message" class="block text-xs uppercase tracking-widest text-[color:var(--color-text-muted)] mb-2">Message</label>
        <textarea id="contact-message" name="message" rows="5" required class="w-full bg-[color:var(--color-bg-soft)] border border-[color:var(--color-border)] rounded px-4 py-3 text-[color:var(--color-text)] focus:outline-none focus:border-[color:var(--color-accent)] transition-colors resize-y"></textarea>
      </div>

      <button type="submit" class="btn btn-primary">Send message</button>
      <p class="mt-3 text-xs text-[color:var(--color-text-muted)]">
        We read every message. Expect a reply within 2 business days.
      </p>
    </form>

    {/* Success confirmation — shown when Formsubmit redirects back with ?sent=1 */}
    <div id="contact-sent" class="hidden mt-8 p-6 rounded border border-[color:var(--color-accent)] bg-[color:var(--color-bg-soft)]">
      <p class="font-display text-2xl mb-2">Message received.</p>
      <p class="text-[color:var(--color-text-soft)]">Thanks — we'll be in touch within 2 business days.</p>
    </div>
  </section>
</BaseLayout>

<script>
  // Show success banner if redirected back with ?sent=1
  (function () {
    if (new URLSearchParams(window.location.search).get("sent") === "1") {
      const banner = document.getElementById("contact-sent");
      const form = document.getElementById("contact-form");
      if (banner) banner.classList.remove("hidden");
      if (form) (form as HTMLFormElement).style.display = "none";
      window.scrollTo({ top: document.body.scrollHeight / 2, behavior: "smooth" });
    }
  })();
</script>
