---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import EventsMap from "../../components/EventsMap.astro";
import Newsletter from "../../components/Newsletter.astro";
import AdSlot from "../../components/AdSlot.astro";
import { upcomingEvents } from "../../data/cigar-events";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => p.data.category === "cigar-events")
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const allCategories = await getCollection("categories");
const category = allCategories.find((c) => c.data.slug === "cigar-events")!;
const categoryByslug = new Map(allCategories.map((c) => [c.data.slug, c.data]));

const upcoming = upcomingEvents();

const fmtRange = (startIso: string, endIso: string) => {
  const start = new Date(startIso);
  const end = new Date(endIso);
  if (start.toDateString() === end.toDateString()) {
    return start.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
  }
  const sameMonth = start.getMonth() === end.getMonth() && start.getFullYear() === end.getFullYear();
  if (sameMonth) {
    return `${start.toLocaleDateString("en-US", { month: "short", day: "numeric" })}–${end.getDate()}, ${end.getFullYear()}`;
  }
  return `${start.toLocaleDateString("en-US", { month: "short", day: "numeric" })} – ${end.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}`;
};
---

<BaseLayout
  title="Cigar Events & Festivals — The Next Cigar"
  description="The cigar festivals, trade shows, and lounges worth flying for. Plus an interactive map of cigar destinations near your location — find your nearest Casa del Habano, retailer, and lounge."
>
  {/* Page header */}
  <section class="container-wide pt-20 md:pt-24 pb-4">
    <nav class="mb-3 text-xs tracking-widest uppercase text-[color:var(--color-text-muted)]" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[color:var(--color-accent)] transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="hover:text-[color:var(--color-accent)] transition-colors">News</a>
      <span class="mx-2">/</span>
      <span class="text-[color:var(--color-text)]">{category.data.name}</span>
    </nav>
    <div class="flex items-baseline justify-between gap-4 flex-wrap">
      <h1 class="font-display text-3xl md:text-5xl leading-tight">Cigar Events &amp; Festivals</h1>
      <p class="text-[color:var(--color-text-muted)] text-sm tracking-wide">
        {upcoming.length} upcoming · {posts.length} {posts.length === 1 ? "story" : "stories"}
      </p>
    </div>
    <p class="mt-3 text-[color:var(--color-text-soft)] max-w-2xl text-base">
      The cigar festivals worth flying for, the trade shows that move the industry,
      and a live map of the lounges and retailers nearest you.
    </p>
  </section>

  {/* Category filter pills */}
  <section class="container-wide pb-6">
    <nav class="flex flex-wrap gap-2" aria-label="Other categories">
      <a href="/blog" class="px-4 py-2 text-sm rounded-sm border border-[color:var(--color-border)] text-[color:var(--color-text-soft)] hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] tracking-wide transition-colors">All stories</a>
      {allCategories.map((c) => (
        <a
          href={`/category/${c.data.slug}`}
          class:list={[
            "px-4 py-2 text-sm rounded-sm tracking-wide transition-colors",
            c.data.slug === category.data.slug
              ? "bg-[color:var(--color-accent)] text-[color:var(--color-bg)]"
              : "border border-[color:var(--color-border)] text-[color:var(--color-text-soft)] hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
          ]}
        >
          {c.data.name}
        </a>
      ))}
    </nav>
  </section>

  {/* ─── INTERACTIVE MAP ─── */}
  <section class="border-t border-[color:var(--color-border)]">
    <EventsMap />
  </section>

  {/* ─── UPCOMING EVENTS CALENDAR ─── */}
  {upcoming.length > 0 && (
    <section class="container-wide py-16 border-t border-[color:var(--color-border)]">
      <div class="flex items-end justify-between mb-10 reveal flex-wrap gap-4">
        <div>
          <p class="section-eyebrow">The calendar</p>
          <h2 class="font-display text-3xl md:text-4xl leading-tight">Upcoming festivals &amp; trade shows</h2>
        </div>
        <p class="text-sm text-[color:var(--color-text-muted)]">
          Dates current as of May 11, 2026
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {upcoming.map((e, i) => (
          <a
            href={e.url}
            target="_blank"
            rel="noopener noreferrer"
            class="event-card reveal"
            data-reveal-delay={((i % 3) + 1) as 1 | 2 | 3}
          >
            <div class="event-card__top">
              <span class={`event-card__badge event-card__badge--${e.type}`}>
                {e.type === "festival" ? "Festival" : e.type === "trade-show" ? "Trade Show" : e.type === "gala" ? "Gala" : "Regional"}
              </span>
              <span class="event-card__date">{fmtRange(e.startDate, e.endDate)}</span>
            </div>
            <h3 class="event-card__name">{e.name}</h3>
            <p class="event-card__location">{e.location}</p>
            <p class="event-card__blurb">{e.blurb}</p>
            <div class="event-card__footer">
              {e.priceFrom && (
                <span class="event-card__price">From {e.priceCurrency === "EUR" ? "€" : e.priceCurrency === "USD" ? "$" : ""}{e.priceFrom}</span>
              )}
              <span class="event-card__cta">Official site →</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* Sponsored ad */}
  <section class="container-wide pb-8">
    <AdSlot variant="leaderboard" />
  </section>

  {/* ─── EDITORIAL POSTS ─── */}
  <section class="container-wide pb-24">
    <div class="flex items-end justify-between mb-10 reveal flex-wrap gap-4">
      <div>
        <p class="section-eyebrow">From the archive</p>
        <h2 class="font-display text-3xl md:text-4xl leading-tight">Stories on the cigar event circuit</h2>
      </div>
    </div>
    {posts.length === 0 ? (
      <p class="text-[color:var(--color-text-muted)]">No stories in this category yet.</p>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {posts.map((post, i) => {
          const c = post.data.category ? categoryByslug.get(post.data.category) : null;
          return <PostCard post={post} categoryName={c?.name} delay={((i % 3) + 1) as 1 | 2 | 3} />;
        })}
      </div>
    )}
  </section>

  <Newsletter />
</BaseLayout>

<style>
  .event-card {
    display: block;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.25rem 1.5rem 1.5rem;
    transition: border-color 0.25s ease, transform 0.25s ease;
    text-decoration: none;
    color: inherit;
  }
  .event-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .event-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    gap: 0.5rem;
  }
  .event-card__badge {
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.3rem 0.6rem;
    border-radius: 3px;
    color: #fff;
    background: var(--color-accent);
  }
  .event-card__badge--trade-show { background: var(--color-burgundy); }
  .event-card__badge--gala { background: #b08968; color: #1f1611; }
  .event-card__badge--regional { background: #1fa0e0; }
  .event-card__date {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-soft);
    letter-spacing: 0.02em;
  }
  .event-card__name {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 0.35rem 0;
    color: var(--color-text);
  }
  .event-card:hover .event-card__name { color: var(--color-headline-hover-on-light); }
  .event-card__location {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 1rem 0;
  }
  .event-card__blurb {
    font-size: 0.94rem;
    line-height: 1.55;
    color: var(--color-text-soft);
    margin: 0 0 1.25rem 0;
  }
  .event-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.82rem;
  }
  .event-card__price { color: var(--color-burgundy); font-weight: 700; }
  .event-card__cta { color: var(--color-accent); font-weight: 700; }
</style>
