---
/**
 * Admin dashboard — read-only overview of all blog posts.
 *
 * Complements Pages CMS:
 *  - Pages CMS handles editing (rich form fields, image upload, GitHub commits)
 *  - This /admin page handles OVERVIEW: status, scheduling visibility, basic SEO scoring
 *
 * Auth: client-side password gate. Set the password in `ADMIN_PASSWORD`
 * env var (Cloudflare Pages > Settings > Environment variables). Defaults
 * to "tnc-admin" if not set so you can develop locally without setup.
 *
 * The gate is security-through-obscurity, not real auth — anyone with the
 * URL + password gets in. For a 1-person publication this is fine. Upgrade
 * to Cloudflare Access if you ever need true auth.
 */

import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const PAGES_CMS_BASE =
  "https://app.pagescms.org/crishavana93-ai/thenextcigar/main/collection/blog";

const adminPassword = import.meta.env.ADMIN_PASSWORD || "tnc-admin";

// Pull all blog posts and compute status + SEO scores
const allPosts = await getCollection("blog");
const allCategories = await getCollection("categories");
const categoryByslug = new Map(allCategories.map((c) => [c.data.slug, c.data]));

const now = new Date();

type Status = "draft" | "scheduled" | "published";

interface PostRow {
  slug: string;
  title: string;
  status: Status;
  publishedAt: Date;
  category: string;
  wordCount: number;
  seoScore: { value: number; flags: string[] };
  pagesCmsUrl: string;
  liveUrl: string;
}

function computeSeoScore(post: any, body: string) {
  const flags: string[] = [];
  let score = 100;

  const title: string = post.data.title || "";
  const excerpt: string = post.data.excerpt || "";
  const metaTitle: string = post.data.seo?.metaTitle || title;
  const metaDescription: string = post.data.seo?.metaDescription || excerpt;
  const focusKeyword: string = post.data.seo?.focusKeyword || "";
  const cover = post.data.cover;

  if (metaTitle.length < 30 || metaTitle.length > 70) {
    flags.push(`Meta title length: ${metaTitle.length} (aim 30–70)`);
    score -= 10;
  }
  if (metaDescription.length < 120 || metaDescription.length > 165) {
    flags.push(`Meta description length: ${metaDescription.length} (aim 120–165)`);
    score -= 10;
  }
  if (!cover) {
    flags.push("No cover image set");
    score -= 15;
  }
  if (!focusKeyword) {
    flags.push("No focus keyword set");
    score -= 5;
  } else {
    const kw = focusKeyword.toLowerCase();
    if (!title.toLowerCase().includes(kw)) {
      flags.push(`Focus keyword "${focusKeyword}" not in title`);
      score -= 8;
    }
    if (!body.toLowerCase().includes(kw)) {
      flags.push(`Focus keyword "${focusKeyword}" not in body`);
      score -= 8;
    }
  }

  // Headings — at least 2 H2s for editorial structure
  const h2Count = (body.match(/^##\s+/gm) || []).length;
  if (h2Count < 2) {
    flags.push(`Only ${h2Count} H2 headings (aim 2+)`);
    score -= 8;
  }

  // Word count — too short = thin content, too long = unfocused
  const words = body.trim().split(/\s+/).filter(Boolean).length;
  if (words < 600) {
    flags.push(`Thin content: ${words} words (aim 800+)`);
    score -= 12;
  }

  return { value: Math.max(0, score), flags };
}

const rows: PostRow[] = allPosts.map((post) => {
  const publishedAt = new Date(post.data.publishedAt);
  let status: Status;
  if (publishedAt > now) status = "scheduled";
  else if (publishedAt.getFullYear() > 2029) status = "draft";
  else status = "published";

  // For scheduled posts >5 years out, treat as draft
  if (status === "scheduled" && publishedAt.getFullYear() > now.getFullYear() + 5) {
    status = "draft";
  }

  const body: string = (post.body || "") as string;
  const seo = computeSeoScore(post, body);
  const wordCount = body.trim().split(/\s+/).filter(Boolean).length;

  const cat = post.data.category ? categoryByslug.get(post.data.category) : null;
  return {
    slug: post.data.slug,
    title: post.data.title,
    status,
    publishedAt,
    category: cat?.name || "—",
    wordCount,
    seoScore: seo,
    pagesCmsUrl: `${PAGES_CMS_BASE}/${post.id}`,
    liveUrl: `https://thenextcigar.com/blog/${post.data.slug}/`,
  };
});

// Sort: drafts first, then scheduled, then published (newest first within group)
const statusOrder: Record<Status, number> = { draft: 0, scheduled: 1, published: 2 };
rows.sort((a, b) => {
  if (a.status !== b.status) return statusOrder[a.status] - statusOrder[b.status];
  return b.publishedAt.getTime() - a.publishedAt.getTime();
});

const counts = {
  draft: rows.filter((r) => r.status === "draft").length,
  scheduled: rows.filter((r) => r.status === "scheduled").length,
  published: rows.filter((r) => r.status === "published").length,
};
---

<BaseLayout title="Admin — TNext Cigar" noIndex={true}>
  <div id="admin-gate" style="position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:9999;background:#ffffff;display:flex;align-items:center;justify-content:center;padding:1.5rem;">
    <div class="max-w-sm w-full" style="position:relative;z-index:10000;">
      <h1 class="font-display text-3xl mb-2">Admin</h1>
      <p class="text-[color:var(--color-text-muted)] text-sm mb-6">Enter password to continue.</p>
      <input
        type="password"
        id="admin-password"
        placeholder="Password"
        class="w-full px-4 py-3 border border-[color:var(--color-border)] rounded-sm focus:outline-none focus:border-[color:var(--color-accent)]"
        autocomplete="current-password"
      />
      <button
        id="admin-submit"
        class="btn btn-accent w-full mt-3"
      >Unlock</button>
      <p id="admin-error" class="text-[color:var(--color-accent)] text-sm mt-3 hidden">Wrong password.</p>
    </div>
  </div>

  <div id="admin-content" class="container-wide pt-20 pb-24 hidden">
    <div class="flex items-baseline justify-between flex-wrap gap-4 mb-8">
      <div>
        <p class="eyebrow mb-2">Admin</p>
        <h1 class="font-display text-4xl">Posts overview</h1>
      </div>
      <div class="flex gap-3 text-sm flex-wrap">
        <span class="px-3 py-1 rounded-sm bg-[color:var(--color-bg-soft)] text-[color:var(--color-text-soft)]">
          {counts.draft} draft
        </span>
        <span class="px-3 py-1 rounded-sm bg-yellow-100 text-yellow-900">
          {counts.scheduled} scheduled
        </span>
        <span class="px-3 py-1 rounded-sm bg-green-100 text-green-900">
          {counts.published} published
        </span>
      </div>
    </div>

    <div class="mb-6 p-4 bg-[color:var(--color-bg-soft)] border border-[color:var(--color-border)] rounded-sm">
      <p class="text-sm text-[color:var(--color-text-soft)]">
        <strong>Workflow:</strong> Click <em>"Edit"</em> on any post → Pages CMS opens with that article loaded → make changes → Save → Cloudflare auto-rebuilds in ~2 min.
        <br/>
        <strong>SEO score</strong> grades each post on title length, meta-description, focus keyword presence, headings, word count, and cover image. Click any flag to see what to fix.
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead class="text-xs uppercase tracking-wider text-[color:var(--color-text-muted)] border-b border-[color:var(--color-border)]">
          <tr>
            <th class="text-left py-3 px-2">Title</th>
            <th class="text-left py-3 px-2">Status</th>
            <th class="text-left py-3 px-2">Date</th>
            <th class="text-left py-3 px-2">Category</th>
            <th class="text-right py-3 px-2">Words</th>
            <th class="text-right py-3 px-2">SEO</th>
            <th class="text-right py-3 px-2">Actions</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class="border-b border-[color:var(--color-border)] hover:bg-[color:var(--color-bg-soft)] transition-colors">
              <td class="py-3 px-2">
                <div class="font-medium">{row.title}</div>
                {row.seoScore.flags.length > 0 && (
                  <details class="text-xs text-[color:var(--color-text-muted)] mt-1">
                    <summary class="cursor-pointer hover:text-[color:var(--color-accent)]">
                      {row.seoScore.flags.length} SEO flag{row.seoScore.flags.length === 1 ? "" : "s"}
                    </summary>
                    <ul class="mt-1 ml-4 list-disc">
                      {row.seoScore.flags.map((f) => <li>{f}</li>)}
                    </ul>
                  </details>
                )}
              </td>
              <td class="py-3 px-2">
                <span class:list={[
                  "px-2 py-0.5 rounded-sm text-xs uppercase tracking-wider",
                  row.status === "draft" && "bg-[color:var(--color-bg-soft)] text-[color:var(--color-text-muted)]",
                  row.status === "scheduled" && "bg-yellow-100 text-yellow-900",
                  row.status === "published" && "bg-green-100 text-green-900",
                ]}>
                  {row.status}
                </span>
              </td>
              <td class="py-3 px-2 text-[color:var(--color-text-soft)]">
                {row.publishedAt.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
              </td>
              <td class="py-3 px-2 text-[color:var(--color-text-soft)]">{row.category}</td>
              <td class="py-3 px-2 text-right text-[color:var(--color-text-soft)]">{row.wordCount}</td>
              <td class="py-3 px-2 text-right">
                <span class:list={[
                  "font-mono font-bold",
                  row.seoScore.value >= 85 && "text-green-700",
                  row.seoScore.value >= 60 && row.seoScore.value < 85 && "text-yellow-700",
                  row.seoScore.value < 60 && "text-red-700",
                ]}>
                  {row.seoScore.value}
                </span>
              </td>
              <td class="py-3 px-2 text-right">
                <a href={row.pagesCmsUrl} target="_blank" rel="noopener" class="text-[color:var(--color-accent)] hover:underline mr-3">Edit</a>
                {row.status === "published" && (
                  <a href={row.liveUrl} target="_blank" rel="noopener" class="text-[color:var(--color-text-soft)] hover:text-[color:var(--color-accent)]">View</a>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-12 pt-6 border-t border-[color:var(--color-border)] text-sm text-[color:var(--color-text-muted)]">
      <p><strong>Build snapshot:</strong> {new Date().toLocaleString("en-US")} — this dashboard reflects posts at the last Cloudflare Pages build. Edit a post and save in Pages CMS to trigger a rebuild and refresh this view.</p>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ adminPassword }}>
  // Simple client-side password gate. Stored hash of the actual password in
  // the build, checked at runtime. Not real auth — fine for a 1-person admin
  // panel behind an unguessable URL. Upgrade to Cloudflare Access for
  // multi-user setups.
  (function () {
    const KEY = "tnc_admin_unlocked";
    const gate = document.getElementById("admin-gate");
    const content = document.getElementById("admin-content");
    const input = document.getElementById("admin-password");
    const submit = document.getElementById("admin-submit");
    const error = document.getElementById("admin-error");

    function unlock() {
      gate.classList.add("hidden");
      content.classList.remove("hidden");
      try { sessionStorage.setItem(KEY, "1"); } catch (e) {}
    }

    function check() {
      if (input.value === adminPassword) {
        unlock();
      } else {
        error.classList.remove("hidden");
        input.value = "";
        input.focus();
      }
    }

    // If already unlocked this session, skip the gate
    try {
      if (sessionStorage.getItem(KEY)) unlock();
    } catch (e) {}

    // Move the gate out of <main> to escape main's z-index:2 stacking context
    // (header/footer have z-index:10 at body level, so a gate inside main
    // could never paint above them no matter how high its own z-index was).
    if (gate.parentElement !== document.body) {
      document.body.appendChild(gate);
    }

    submit.addEventListener("click", check);
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter") check();
    });
    input.focus();
  })();
</script>
