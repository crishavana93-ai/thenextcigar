---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Sign in — The Lounge"
  description="Sign in to The Lounge — The Next Cigar's members network."
  noIndex
>
  <section class="lounge-auth">
    <div class="lounge-auth__inner reveal">
      <p class="lounge-auth__eyebrow">The Lounge · Welcome back</p>
      <h1 class="lounge-auth__title">Sign in.</h1>
      <p class="lounge-auth__lead">
        Email + password. Or use the older magic-link option below if you haven't set a password yet.
      </p>

      {/* ── Primary: email + password login ─────────────────────────────── */}
      <form id="login-pw-form" class="lounge-auth__form">
        <label class="lounge-auth__label">
          Email
          <input type="email" name="email" required autocomplete="email" placeholder="your-email@anywhere.com" />
        </label>

        <label class="lounge-auth__label">
          Password
          <input type="password" name="password" required minlength="8" autocomplete="current-password" placeholder="••••••••" />
        </label>

        <button type="submit" class="lounge-auth__button">Sign in →</button>

        <button type="button" id="login-forgot" class="lounge-auth__ghost">
          First time? Set a password
        </button>
      </form>

      {/* ── Fallback: magic-link / OTP code ──────────────────────────────── */}
      <details class="lounge-auth__details">
        <summary>Or sign in with an email link instead</summary>

        <form id="login-magic-form" class="lounge-auth__form" style="margin-top: 1rem;">
          <label class="lounge-auth__label">
            Email
            <input type="email" name="email" required autocomplete="email" placeholder="your-email@anywhere.com" />
          </label>
          <button type="submit" class="lounge-auth__button lounge-auth__button--secondary">
            Email me a sign-in link →
          </button>
        </form>

        {/* Code-entry form — shown after the magic-link email is sent */}
        <form id="login-code-form" class="lounge-auth__form" hidden style="margin-top: 1rem;">
          <label class="lounge-auth__label">
            6-digit code <span style="color:var(--color-text-muted); font-weight:500;">— check your email</span>
            <input
              type="text"
              name="token"
              required
              inputmode="numeric"
              autocomplete="one-time-code"
              maxlength="6"
              pattern="[0-9]{6}"
              placeholder="123456"
              style="font-size: 1.4rem; letter-spacing: 0.4em; text-align: center; font-family: var(--font-display); font-weight: 800;" />
          </label>
          <button type="submit" class="lounge-auth__button">Sign in →</button>
          <button type="button" id="login-resend" class="lounge-auth__ghost">Resend the code</button>
        </form>
      </details>

      <p id="login-status" class="lounge-auth__status" hidden></p>

      <p class="lounge-auth__alt">
        Not a member yet? <a href="/lounge/signup/">Reserve your place</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .lounge-auth {
    min-height: calc(100vh - 80px);
    background:
      radial-gradient(circle at 15% 25%, rgba(110, 38, 32, 0.10), transparent 55%),
      radial-gradient(circle at 85% 75%, rgba(255, 46, 46, 0.06), transparent 55%),
      var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
  }
  .lounge-auth__inner {
    width: 100%;
    max-width: 28rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 2.5rem;
  }
  .lounge-auth__eyebrow {
    font-size: 0.7rem; font-weight: 800; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--color-accent); margin: 0 0 0.85rem 0;
  }
  .lounge-auth__title {
    font-family: var(--font-display); font-size: 2.25rem; font-weight: 800;
    line-height: 1.05; letter-spacing: -0.02em;
    color: var(--color-text); margin: 0 0 0.85rem 0;
  }
  .lounge-auth__lead {
    font-size: 0.95rem; line-height: 1.55;
    color: var(--color-text-soft); margin: 0 0 1.5rem 0;
  }
  .lounge-auth__form { display: flex; flex-direction: column; gap: 1rem; }
  .lounge-auth__label {
    display: flex; flex-direction: column; gap: 0.4rem;
    font-size: 0.78rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--color-text-muted);
  }
  .lounge-auth__label input {
    padding: 0.75rem 0.85rem; border: 1px solid var(--color-border);
    border-radius: 3px; background: #fff; font-size: 0.95rem;
    color: var(--color-text); text-transform: none; letter-spacing: normal;
  }
  .lounge-auth__label input:focus { outline: 2px solid var(--color-accent); outline-offset: 1px; }
  .lounge-auth__button {
    margin-top: 0.4rem; padding: 0.65rem 1.2rem;
    background: var(--color-accent); color: #fff; border: none; border-radius: 999px;
    font-size: 0.76rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    cursor: pointer; transition: background 0.15s ease;
  }
  .lounge-auth__button:hover { background: var(--color-accent-hover); }
  .lounge-auth__button:disabled { opacity: 0.6; cursor: wait; }
  .lounge-auth__button--secondary {
    background: transparent;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
  }
  .lounge-auth__button--secondary:hover {
    background: rgba(110, 38, 32, 0.08);
  }
  .lounge-auth__ghost {
    background: none; border: none;
    color: var(--color-gold, #c9a961);
    text-decoration: underline;
    cursor: pointer;
    padding: 8px 0; font: inherit;
    margin-top: 4px;
    font-size: 0.85rem;
    text-align: center;
  }
  .lounge-auth__details {
    margin-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
  }
  .lounge-auth__details summary {
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding: 4px 0;
    list-style: none;
  }
  .lounge-auth__details summary::-webkit-details-marker { display: none; }
  .lounge-auth__details summary::before {
    content: "› ";
    display: inline-block;
    transition: transform 0.15s ease;
    color: var(--color-gold, #c9a961);
    font-weight: 700;
  }
  .lounge-auth__details[open] summary::before {
    transform: rotate(90deg);
  }
  .lounge-auth__status {
    margin-top: 1rem; padding: 0.85rem 1rem;
    background: var(--color-cream); border-left: 3px solid var(--color-accent);
    border-radius: 3px; font-size: 0.88rem; line-height: 1.5; color: var(--color-text);
  }
  .lounge-auth__status.is-error { background: #fde9e9; border-color: #c62828; }
  .lounge-auth__alt {
    margin-top: 1.25rem; text-align: center;
    font-size: 0.85rem; color: var(--color-text-muted);
  }
  .lounge-auth__alt a { color: var(--color-accent); font-weight: 600; text-decoration: underline; }
</style>

<script>
  import { getSupabase, getCurrentUser } from "../../lib/supabase";

  const LAST_EMAIL_KEY = "lounge_last_email";

  function showStatus(msg: string, isError = false) {
    const status = document.getElementById("login-status") as HTMLParagraphElement | null;
    if (!status) return;
    status.hidden = false;
    status.classList.toggle("is-error", isError);
    status.innerHTML = msg;
  }

  async function setup() {
    // If already signed in, skip the form
    const user = await getCurrentUser();
    if (user) {
      window.location.href = "/lounge/app/";
      return;
    }

    // Pre-fill saved email on both forms
    let savedEmail: string | null = null;
    try { savedEmail = localStorage.getItem(LAST_EMAIL_KEY); } catch {}
    if (savedEmail) {
      document.querySelectorAll<HTMLInputElement>('input[type=email]').forEach((el) => {
        if (!el.value) el.value = savedEmail!;
      });
    }

    // ── Primary: password sign-in ───────────────────────────────────────
    const pwForm = document.getElementById("login-pw-form") as HTMLFormElement | null;
    pwForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(pwForm);
      const email = String(fd.get("email") || "").trim();
      const password = String(fd.get("password") || "");
      if (!email || !password) return;

      const btn = pwForm.querySelector("button[type=submit]") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Signing in…";
      try {
        const supabase = getSupabase();
        const { error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) throw error;
        try { localStorage.setItem(LAST_EMAIL_KEY, email); } catch {}
        window.location.href = "/lounge/app/";
      } catch (err: any) {
        // Common case: existing user has no password set yet (signed up via
        // magic link before passwords were a thing). Steer them to the
        // forgot-password flow instead of just showing a confusing error.
        const msg = err?.message || "";
        const looksLikeNoPassword =
          /invalid login credentials/i.test(msg) || /invalid_grant/i.test(msg);
        if (looksLikeNoPassword) {
          showStatus(
            `That email exists but no password is set yet. Tap <strong>"First time? Set a password"</strong> below to get a reset email — takes 30 seconds.`,
            true,
          );
        } else {
          showStatus(err?.message || "Sign-in failed. Try again.", true);
        }
        btn.disabled = false;
        btn.textContent = "Sign in →";
      }
    });

    // ── "First time? Set a password" — sends reset email ───────────────
    document.getElementById("login-forgot")?.addEventListener("click", async () => {
      const emailInput = pwForm?.querySelector('input[name=email]') as HTMLInputElement;
      const email = emailInput.value.trim();
      if (!email) {
        emailInput.focus();
        showStatus("Enter your email first, then tap this again.", true);
        return;
      }
      const btn = document.getElementById("login-forgot") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Sending email…";
      try {
        const supabase = getSupabase();
        const { error } = await supabase.auth.resetPasswordForEmail(email, {
          redirectTo: `${window.location.origin}/lounge/reset-password/`,
        });
        if (error) throw error;
        try { localStorage.setItem(LAST_EMAIL_KEY, email); } catch {}
        showStatus(
          `Email sent to <strong>${email}</strong>. Click the "Set password" link inside — works from any device, any browser. After you set the password, come back here and sign in.`,
        );
      } catch (err: any) {
        showStatus(err?.message || "Couldn't send reset email. Try again.", true);
      } finally {
        btn.disabled = false;
        btn.textContent = "First time? Set a password";
      }
    });

    // ── Fallback: magic-link / OTP code ─────────────────────────────────
    const magicForm = document.getElementById("login-magic-form") as HTMLFormElement | null;
    const codeForm = document.getElementById("login-code-form") as HTMLFormElement | null;
    let lastEmailSent = "";

    async function sendMagicLink(email: string) {
      const supabase = getSupabase();
      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: { emailRedirectTo: `${window.location.origin}/lounge/app/` },
      });
      if (error) throw error;
      lastEmailSent = email;
      try { localStorage.setItem(LAST_EMAIL_KEY, email); } catch {}
    }

    magicForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(magicForm);
      const email = String(fd.get("email") || "").trim();
      if (!email) return;
      const btn = magicForm.querySelector("button[type=submit]") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Sending…";
      try {
        await sendMagicLink(email);
        showStatus(`Sent. Open the email from <strong>The Lounge</strong> and tap the link, OR copy the 6-digit code into the form below.`);
        if (codeForm) {
          codeForm.hidden = false;
          (codeForm.querySelector("input[name=token]") as HTMLInputElement).focus();
        }
      } catch (err: any) {
        showStatus(err?.message || "Couldn't send. Try again.", true);
        btn.disabled = false;
        btn.textContent = "Email me a sign-in link →";
      }
    });

    codeForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const token = (codeForm.querySelector("input[name=token]") as HTMLInputElement).value.trim();
      if (!/^\d{6}$/.test(token)) return;
      const btn = codeForm.querySelector("button[type=submit]") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Signing in…";
      try {
        const supabase = getSupabase();
        const { error } = await supabase.auth.verifyOtp({
          email: lastEmailSent || localStorage.getItem(LAST_EMAIL_KEY) || "",
          token,
          type: "email",
        });
        if (error) throw error;
        window.location.href = "/lounge/app/";
      } catch (err: any) {
        showStatus(err?.message || "Invalid or expired code. Tap Resend below.", true);
        btn.disabled = false;
        btn.textContent = "Sign in →";
      }
    });

    document.getElementById("login-resend")?.addEventListener("click", async () => {
      const email = lastEmailSent || localStorage.getItem(LAST_EMAIL_KEY) || "";
      if (!email) return;
      try {
        await sendMagicLink(email);
        showStatus(`Resent. Check your inbox.`);
      } catch (err: any) {
        showStatus(err?.message || "Couldn't resend.", true);
      }
    });
  }

  document.addEventListener("astro:page-load", setup);
  setup();
</script>
