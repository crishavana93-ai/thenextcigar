---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LoungeHeader from "../../../components/lounge/LoungeHeader.astro";
import LoungeTabBar from "../../../components/lounge/LoungeTabBar.astro";
import IntroSheet from "../../../components/lounge/IntroSheet.astro";
---

<BaseLayout
  title="Member profile — The Lounge"
  description="Member profile view."
  noIndex
>
  <LoungeHeader active="directory" />

  <main class="lounge-app">
    <div id="lounge-guard" class="lskel-page">
      <p class="lskel-kicker">Loading profile</p>

      <div style="display:flex;flex-direction:column;align-items:center;padding:24px 16px;background:var(--color-bg);border-radius:12px;">
        <span class="lskel lskel--circle" style="width:112px;height:112px;border:3px solid var(--color-gold-soft);"></span>
        <span class="lskel lskel--line-xl" style="width:220px;margin-top:18px;"></span>
        <span class="lskel lskel--line" style="width:120px;margin-top:8px;"></span>
        <div style="display:flex;gap:6px;margin-top:14px;">
          <span class="lskel lskel--pill" style="width:90px;height:22px;"></span>
          <span class="lskel lskel--pill" style="width:60px;height:22px;"></span>
          <span class="lskel lskel--pill" style="width:110px;height:22px;"></span>
        </div>
        <div style="margin-top:18px;padding-top:18px;border-top:1px solid var(--color-gold-soft);width:100%;max-width:28rem;display:flex;justify-content:center;gap:6px;">
          <span class="lskel lskel--pill" style="width:160px;height:26px;"></span>
          <span class="lskel lskel--pill" style="width:120px;height:26px;"></span>
        </div>
      </div>

      <div style="max-width:32rem;margin:24px auto 0;">
        <span class="lskel lskel--line" style="width:100%;margin-bottom:8px;"></span>
        <span class="lskel lskel--line" style="width:88%;margin-bottom:8px;"></span>
        <span class="lskel lskel--line" style="width:75%;"></span>
      </div>
    </div>

    <div id="lounge-content" hidden>
      <section class="container-wide pt-8 md:pt-12 pb-2">
        <a href="/lounge/app/directory/" class="lounge-mem-back">← All members</a>
      </section>

      <section class="container-wide pt-2 pb-6 reveal">
        <div class="lounge-mem-hero">
          <div class="lounge-mem-hero__avatar" id="mem-avatar">?</div>
          <h1 class="lounge-mem-hero__name" id="mem-name">…</h1>
          <p class="lounge-mem-hero__city" id="mem-city">—</p>
          <div class="lounge-mem-hero__badges" id="mem-badges"></div>
          {/* Signal strip — shared context (same city, trip overlap, shared venue) */}
          <div class="lounge-mem-signal" id="mem-signal" hidden></div>
        </div>
      </section>

      <section class="container-wide pb-6">
        <p class="lounge-mem-bio" id="mem-bio">—</p>
      </section>

      <section class="container-wide pb-24" id="mem-actions-section">
        <div id="mem-self-notice" hidden class="lounge-mem-self">
          <p class="lounge-mem-self__row">This is your own profile.</p>
          <a href="/lounge/app/profile/" class="lounge-mem-self__cta">Edit your profile →</a>
        </div>

        <div id="mem-intro-state-existing" hidden class="lounge-mem-intro lounge-mem-intro--pending">
          <p class="lounge-mem-intro__eyebrow" id="mem-intro-eyebrow">Introduction status</p>
          <p class="lounge-mem-intro__body" id="mem-intro-body">—</p>
        </div>

        <div id="mem-intro-form-wrap" hidden>
          <button id="mem-intro-cta" class="lounge-mem-cta" type="button">Request an introduction</button>

          <form id="mem-intro-form" class="lounge-mem-intro-form" hidden>
            <label class="lounge-mem-intro-form__label">
              Context
              <select name="context" required>
                <option value="manual" selected>I just want to say hello</option>
                <option value="travel_plan">I'm traveling to their city</option>
                <option value="host_intro">I'd like to host them</option>
                <option value="lounge_check_in">We're at the same lounge</option>
              </select>
            </label>

            <label class="lounge-mem-intro-form__label">
              Message (max 500 chars)
              <textarea name="intro_message" required rows="4" maxlength="500"
                placeholder="A line or two about why you'd like to meet."></textarea>
            </label>

            <div class="lounge-mem-intro-form__actions">
              <button type="button" id="mem-intro-cancel" class="lounge-mem-intro-form__cancel">Cancel</button>
              <button type="submit" class="lounge-mem-intro-form__submit">Send request →</button>
            </div>

            <p id="mem-intro-status" hidden class="lounge-mem-intro-form__status"></p>
          </form>
        </div>
      </section>
    </div>

    <section id="lounge-not-found" hidden class="container-wide py-24 text-center">
      <p class="section-eyebrow">Not found</p>
      <h1 class="font-display text-4xl mt-2">No such member.</h1>
      <p class="mt-4 text-[color:var(--color-text-soft)]">
        That profile doesn't exist or has been removed.
      </p>
      <p class="mt-6">
        <a href="/lounge/app/directory/" class="lounge-mem-back">← Back to the directory</a>
      </p>
    </section>
  </main>
  <LoungeTabBar active="members" />
  <IntroSheet />
</BaseLayout>

<style>
  .lounge-app { min-height: calc(100vh - 80px); background: var(--color-bg); }

  .lounge-app__guard {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lounge-app__guard-eyebrow {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .lounge-mem-back {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .lounge-mem-back:hover { color: var(--color-accent); }

  /* ── Hero region — bigger avatar, centered, gold-accented ─────────────── */
  .lounge-mem-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 32px 16px 8px;
    background:
      radial-gradient(ellipse at top, rgba(201, 169, 97, 0.08) 0%, transparent 60%),
      var(--color-bg);
    border-radius: 12px;
  }
  .lounge-mem-hero__avatar {
    width: 112px;
    height: 112px;
    border-radius: 50%;
    background: var(--color-bg-soft);
    border: 3px solid var(--color-gold, #c9a961);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--color-text-muted);
    overflow: hidden;
    flex-shrink: 0;
  }
  .lounge-mem-hero__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .lounge-mem-hero__name {
    margin: 8px 0 0 0;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text);
    text-align: center;
  }
  .lounge-mem-hero__city {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-gold, #c9a961);
  }
  .lounge-mem-hero__badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    margin-top: 8px;
  }
  /* Signal-strip lozenges: shared context cues ("you're both in Stockholm") */
  .lounge-mem-signal {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid rgba(201, 169, 97, 0.22);
    width: 100%;
    max-width: 32rem;
  }
  .lounge-mem-signal__loz {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--color-gold-soft, rgba(201, 169, 97, 0.18));
    border: 1px solid rgba(201, 169, 97, 0.4);
    color: var(--color-charcoal, #1a1d2e);
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
  }
  .lounge-mem-bio {
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0 auto;
    max-width: 56ch;
    text-align: center;
    white-space: pre-line;
  }

  /* Legacy classes (still rendered by the old `.lounge-mem-head` blocks elsewhere) */
  .lounge-mem-head {
    display: flex;
    gap: 1.75rem;
    align-items: flex-start;
    flex-wrap: wrap;
  }
  .lounge-mem-head__avatar {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-text-muted);
    overflow: hidden;
    flex-shrink: 0;
  }
  .lounge-mem-head__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .lounge-mem-head__city {
    margin: 0.4rem 0 0 0;
    font-size: 0.92rem;
    color: var(--color-text-soft);
  }
  .lounge-mem-head__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.9rem;
  }
  .lounge-mem-head__badge {
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: 3px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .lounge-mem-head__badge--founding {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .lounge-mem-head__badge--host {
    background: var(--color-burgundy);
    color: #fff;
    border-color: var(--color-burgundy);
  }

  .lounge-mem-card {
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.5rem 1.85rem;
    max-width: 48rem;
  }
  .lounge-mem-card__label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.6rem 0;
  }
  .lounge-mem-card__body {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0;
    white-space: pre-line;
  }

  .lounge-mem-self {
    max-width: 48rem;
    background: var(--color-cream);
    border-left: 3px solid var(--color-accent);
    border-radius: 3px;
    padding: 1.25rem 1.5rem;
  }
  .lounge-mem-self__row {
    margin: 0;
    color: var(--color-text);
    font-size: 0.95rem;
  }
  .lounge-mem-self__cta {
    display: inline-block;
    margin-top: 0.75rem;
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.85rem;
    text-decoration: underline;
  }

  .lounge-mem-intro {
    max-width: 48rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
  }
  .lounge-mem-intro--pending { border-left: 3px solid var(--color-accent); }
  .lounge-mem-intro--accepted { border-left: 3px solid #16a34a; }
  .lounge-mem-intro--declined { border-left: 3px solid #c62828; opacity: 0.85; }
  .lounge-mem-intro__eyebrow {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem 0;
  }
  .lounge-mem-intro__body {
    margin: 0;
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .lounge-mem-cta {
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: 999px;
    padding: 0.65rem 1.3rem;
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .lounge-mem-cta:hover { background: var(--color-accent-hover); }
  .lounge-mem-cta:disabled { opacity: 0.6; cursor: wait; }

  .lounge-mem-intro-form {
    margin-top: 1.25rem;
    max-width: 48rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .lounge-mem-intro-form__label {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }
  .lounge-mem-intro-form__label select,
  .lounge-mem-intro-form__label textarea {
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    background: #fff;
    font-size: 0.95rem;
    color: var(--color-text);
    text-transform: none;
    letter-spacing: normal;
    font-family: inherit;
    resize: vertical;
  }
  .lounge-mem-intro-form__label select:focus,
  .lounge-mem-intro-form__label textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }
  .lounge-mem-intro-form__actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .lounge-mem-intro-form__cancel {
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.7rem 1.1rem;
    border-radius: 3px;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
  }
  .lounge-mem-intro-form__submit {
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: 999px;
    padding: 0.6rem 1.2rem;
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    margin-left: auto;
  }
  .lounge-mem-intro-form__submit:hover { background: var(--color-accent-hover); }
  .lounge-mem-intro-form__submit:disabled { opacity: 0.6; cursor: wait; }
  .lounge-mem-intro-form__status {
    margin: 0;
    padding: 0.85rem 1rem;
    background: var(--color-cream);
    border-left: 3px solid var(--color-accent);
    border-radius: 3px;
    font-size: 0.88rem;
    color: var(--color-text);
  }
  .lounge-mem-intro-form__status.is-error {
    background: #fde9e9;
    border-color: #c62828;
  }
</style>

<script>
  import { getCurrentUser, getSupabase } from "../../../lib/supabase";

  type ProfileRow = {
    id: string;
    display_name: string | null;
    city: string | null;
    country_code: string | null;
    bio: string | null;
    avatar_url: string | null;
    is_host: boolean | null;
    is_founding: boolean | null;
    joined_at: string | null;
  };

  type IntroRow = {
    id: string;
    accepted: boolean | null;
    intro_message: string;
    context: string;
    created_at: string;
  };

  function escapeHtml(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function initials(name: string | null): string {
    if (!name) return "?";
    const parts = name.trim().split(/\s+/);
    const first = parts[0]?.[0] || "";
    const second = parts[1]?.[0] || "";
    return (first + second).toUpperCase() || "?";
  }

  function getIdFromUrl(): string | null {
    const params = new URLSearchParams(window.location.search);
    return params.get("id");
  }

  async function init(): Promise<void> {
    const user = await getCurrentUser();
    if (!user) {
      window.location.href = "/lounge/login/";
      return;
    }

    const memberId = getIdFromUrl();
    if (!memberId) {
      window.location.href = "/lounge/app/directory/";
      return;
    }

    const supabase = getSupabase();
    const { data: profile, error } = await supabase
      .from("profiles")
      .select("id, display_name, city, country_code, bio, avatar_url, is_host, is_founding, joined_at, favorite_brands, flavor_notes, strength_preference")
      .eq("id", memberId)
      .maybeSingle();

    const guard = document.getElementById("lounge-guard");
    const content = document.getElementById("lounge-content");
    const notFound = document.getElementById("lounge-not-found");

    if (error || !profile) {
      console.error("[Lounge member] failed to load profile:", error);
      if (guard) guard.style.display = "none";
      if (notFound) notFound.hidden = false;
      return;
    }

    const p = profile as ProfileRow;

    // Populate head
    const avatarEl = document.getElementById("mem-avatar");
    if (avatarEl) {
      if (p.avatar_url) {
        avatarEl.innerHTML = `<img src="${p.avatar_url}" alt="" />`;
      } else {
        avatarEl.textContent = initials(p.display_name);
      }
    }
    const nameEl = document.getElementById("mem-name");
    if (nameEl) nameEl.textContent = p.display_name || "Member";
    const cityEl = document.getElementById("mem-city");
    if (cityEl) cityEl.textContent = p.city ? `${p.city}${p.country_code ? ` · ${p.country_code}` : ""}` : "City not set";
    const bioEl = document.getElementById("mem-bio");
    if (bioEl) bioEl.textContent = p.bio || "This member hasn't written a bio yet.";

    // Badges
    const badges = document.getElementById("mem-badges");
    if (badges) {
      const parts: string[] = [];
      if (p.is_founding) parts.push(`<span class="lounge-mem-head__badge lounge-mem-head__badge--founding">Founding member</span>`);
      if (p.is_host) parts.push(`<span class="lounge-mem-head__badge lounge-mem-head__badge--host">Host</span>`);
      if (p.joined_at) {
        const d = new Date(p.joined_at);
        parts.push(`<span class="lounge-mem-head__badge">Joined ${d.toLocaleDateString("en-US", { month: "short", year: "numeric" })}</span>`);
      }
      badges.innerHTML = parts.join("");
    }

    // ── Signal strip (shared context) ──────────────────────────────────────
    // Compute small lozenges describing what THIS viewer has in common with
    // the member they're looking at. Surfaces:
    //   - "You're both in <city>"
    //   - "Your trips overlap" (Jun 8–12)
    //   - "Both checked in at <venue> in the last 7 days"
    const signalEl = document.getElementById("mem-signal");
    if (signalEl && p.id !== user.id) {
      const lozenges: string[] = [];

      // Pull viewer's own profile so we can compute overlap signals
      // (shared city, shared brands, shared flavor notes, same strength).
      const { data: meProfile } = await supabase
        .from("profiles")
        .select("city, favorite_brands, flavor_notes, strength_preference")
        .eq("id", user.id)
        .maybeSingle();

      if (meProfile?.city && p.city && meProfile.city === p.city) {
        lozenges.push(`<span class="lounge-mem-signal__loz">You're both in ${escapeHtml(p.city)}</span>`);
      }

      // Trip overlap — fetch both members' upcoming trips and intersect
      const today = new Date().toISOString().slice(0, 10);
      const { data: tripsMine } = await supabase
        .from("travel_plans")
        .select("city, arrive_date, depart_date")
        .eq("member_id", user.id)
        .gte("depart_date", today);
      const { data: tripsTheirs } = await supabase
        .from("travel_plans")
        .select("city, arrive_date, depart_date")
        .eq("member_id", p.id)
        .gte("depart_date", today);
      const tripsMineRows = (tripsMine as any[]) || [];
      const tripsTheirsRows = (tripsTheirs as any[]) || [];
      outer: for (const a of tripsMineRows) {
        for (const b of tripsTheirsRows) {
          if (a.city.toLowerCase() === b.city.toLowerCase()) {
            // Date overlap?
            if (a.arrive_date <= b.depart_date && b.arrive_date <= a.depart_date) {
              lozenges.push(`<span class="lounge-mem-signal__loz">Your trips overlap in ${escapeHtml(a.city)}</span>`);
              break outer;
            }
          }
        }
      }
      // Trips one-way (they're coming to your city)
      if (meProfile?.city) {
        const matching = tripsTheirsRows.find((t) => t.city.toLowerCase() === meProfile.city.toLowerCase());
        if (matching && !lozenges.some((l) => l.includes("trips overlap"))) {
          const d1 = new Date(matching.arrive_date + "T00:00:00").toLocaleDateString("en-US", { month: "short", day: "numeric" });
          const d2 = new Date(matching.depart_date + "T00:00:00").toLocaleDateString("en-US", { month: "short", day: "numeric" });
          lozenges.push(`<span class="lounge-mem-signal__loz">Coming to your city ${d1}–${d2}</span>`);
        }
      }

      // Flavor profile overlaps. Cap each lozenge at 2–3 names so it stays
      // readable. Only surface overlap when both sides have set the field
      // (otherwise an empty array would "match" against everything).
      const myBrands: string[] = ((meProfile as any)?.favorite_brands as string[]) || [];
      const theirBrands: string[] = ((p as any).favorite_brands as string[]) || [];
      if (myBrands.length && theirBrands.length) {
        const shared = myBrands.filter((b) => theirBrands.includes(b));
        if (shared.length > 0) {
          const preview = shared.slice(0, 2).map(escapeHtml).join(" and ");
          const more = shared.length > 2 ? ` +${shared.length - 2}` : "";
          lozenges.push(`<span class="lounge-mem-signal__loz">You both love ${preview}${more}</span>`);
        }
      }

      const myNotes: string[] = ((meProfile as any)?.flavor_notes as string[]) || [];
      const theirNotes: string[] = ((p as any).flavor_notes as string[]) || [];
      if (myNotes.length && theirNotes.length) {
        const sharedNotes = myNotes.filter((n) => theirNotes.includes(n));
        if (sharedNotes.length >= 2) {
          const preview = sharedNotes.slice(0, 2).map((n) => escapeHtml(n.toLowerCase())).join(" and ");
          lozenges.push(`<span class="lounge-mem-signal__loz">You share a love for ${preview} notes</span>`);
        }
      }

      const myStrength = (meProfile as any)?.strength_preference as string | null;
      const theirStrength = (p as any).strength_preference as string | null;
      if (myStrength && theirStrength && myStrength === theirStrength) {
        const label =
          myStrength === "mild" ? "mild" :
          myStrength === "medium" ? "medium-bodied" :
          myStrength === "full" ? "full-bodied" :
          myStrength === "extra_full" ? "extra full-bodied" :
          myStrength;
        lozenges.push(`<span class="lounge-mem-signal__loz">You both prefer ${label} cigars</span>`);
      }

      if (lozenges.length > 0) {
        signalEl.innerHTML = lozenges.join("");
        signalEl.hidden = false;
      }
    }

    // Action section
    const selfNotice = document.getElementById("mem-self-notice");
    const introExisting = document.getElementById("mem-intro-state-existing");
    const introFormWrap = document.getElementById("mem-intro-form-wrap");

    if (p.id === user.id) {
      if (selfNotice) selfNotice.hidden = false;
    } else {
      // Check for existing intro
      const { data: existing } = await supabase
        .from("introductions")
        .select("id, accepted, intro_message, context, created_at")
        .eq("from_member_id", user.id)
        .eq("to_member_id", p.id)
        .maybeSingle();

      if (existing) {
        const intro = existing as IntroRow;
        if (introExisting) {
          introExisting.hidden = false;
          const eyebrow = document.getElementById("mem-intro-eyebrow");
          const body = document.getElementById("mem-intro-body");
          let status = "Pending — waiting on response";
          let cls = "lounge-mem-intro--pending";
          let extraHtml = "";
          if (intro.accepted === true) {
            status = "Accepted. Direct messages are unlocked.";
            cls = "lounge-mem-intro--accepted";
            extraHtml = `<a class="lounge-mem-cta" style="display:inline-block;margin-top:12px;text-decoration:none;" href="/lounge/app/messages/?with=${p.id}">Open conversation →</a>`;
          } else if (intro.accepted === false) {
            status = "Declined — try again later or in person";
            cls = "lounge-mem-intro--declined";
          }
          introExisting.className = `lounge-mem-intro ${cls}`;
          if (eyebrow) eyebrow.textContent = "Introduction status";
          if (body) {
            body.innerHTML = `${escapeHtml(status)}${extraHtml}`;
          }
        }
      } else {
        if (introFormWrap) introFormWrap.hidden = false;
        wireIntroForm(user.id, p.id);
      }
    }

    if (guard) guard.style.display = "none";
    if (content) content.hidden = false;
  }

  function wireIntroForm(fromId: string, toId: string): void {
    const cta = document.getElementById("mem-intro-cta") as HTMLButtonElement | null;
    const form = document.getElementById("mem-intro-form") as HTMLFormElement | null;
    const cancel = document.getElementById("mem-intro-cancel") as HTMLButtonElement | null;
    const status = document.getElementById("mem-intro-status") as HTMLParagraphElement | null;
    if (!cta || !form || !cancel) return;

    cta.addEventListener("click", () => {
      form.hidden = false;
      cta.hidden = true;
    });
    cancel.addEventListener("click", () => {
      form.hidden = true;
      cta.hidden = false;
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";

      const fd = new FormData(form);
      const context = String(fd.get("context") || "manual");
      const intro_message = String(fd.get("intro_message") || "").trim();

      if (!intro_message) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send request →";
        return;
      }

      try {
        const supabase = getSupabase();
        const { error } = await supabase.from("introductions").insert({
          from_member_id: fromId,
          to_member_id: toId,
          context,
          intro_message,
        });
        if (error) throw error;

        if (status) {
          status.hidden = false;
          status.classList.remove("is-error");
          status.innerHTML = `<strong>Request sent.</strong> You'll get an email when they respond.`;
        }
        form.querySelector('textarea')?.setAttribute('disabled', '');
        form.querySelector('select')?.setAttribute('disabled', '');
        cancel.style.display = "none";
        submitBtn.style.display = "none";
      } catch (err: any) {
        if (status) {
          status.hidden = false;
          status.classList.add("is-error");
          status.textContent = err?.message || "Could not send. Try again.";
        }
        submitBtn.disabled = false;
        submitBtn.textContent = "Send request →";
      }
    });
  }

  document.addEventListener("astro:page-load", init);
  init();
</script>
