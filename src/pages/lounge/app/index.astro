---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LoungeHeader from "../../../components/lounge/LoungeHeader.astro";
import LoungeTabBar from "../../../components/lounge/LoungeTabBar.astro";
---

<BaseLayout
  title="The Lounge — Member Dashboard"
  description="Your home base inside The Lounge."
  noIndex
>
  <LoungeHeader active="dashboard" />

  <main class="lounge-app">
    {/* Auth guard — feed-shaped skeleton so the page looks alive before data lands */}
    <div id="lounge-guard" class="lskel-page">
      <p class="lskel-kicker">Loading the Lounge</p>

      {/* Status strip skeleton */}
      <div style="display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--color-bg-soft);border:1px solid var(--color-gold-soft);border-radius:10px;margin-bottom:20px;">
        <span class="lskel lskel--circle" style="width:48px;height:48px;"></span>
        <span style="flex-grow:1;display:flex;flex-direction:column;gap:6px;">
          <span class="lskel lskel--line-lg" style="width:55%;"></span>
          <span class="lskel lskel--line" style="width:35%;"></span>
        </span>
        <span class="lskel lskel--pill" style="width:120px;"></span>
      </div>

      {/* Live-now strip skeleton */}
      <span class="lskel lskel--line" style="width:140px;margin:18px 0 10px;"></span>
      <div class="lskel-strip">
        <span class="lskel" style="width:110px;height:130px;"></span>
        <span class="lskel" style="width:110px;height:130px;"></span>
        <span class="lskel" style="width:110px;height:130px;"></span>
        <span class="lskel" style="width:110px;height:130px;"></span>
      </div>

      {/* Feed rows skeleton */}
      <span class="lskel lskel--line" style="width:160px;margin:24px 0 6px;"></span>
      <div class="lskel-row"><span class="lskel lskel--circle lskel-row__avatar"></span><span class="lskel-row__main"><span class="lskel lskel--line" style="width:80%;"></span><span class="lskel lskel--line" style="width:22%;"></span></span></div>
      <div class="lskel-row"><span class="lskel lskel--circle lskel-row__avatar"></span><span class="lskel-row__main"><span class="lskel lskel--line" style="width:65%;"></span><span class="lskel lskel--line" style="width:30%;"></span></span></div>
      <div class="lskel-row"><span class="lskel lskel--circle lskel-row__avatar"></span><span class="lskel-row__main"><span class="lskel lskel--line" style="width:75%;"></span><span class="lskel lskel--line" style="width:18%;"></span></span></div>
      <div class="lskel-row"><span class="lskel lskel--circle lskel-row__avatar"></span><span class="lskel-row__main"><span class="lskel lskel--line" style="width:60%;"></span><span class="lskel lskel--line" style="width:26%;"></span></span></div>
    </div>

    <div id="lounge-content" hidden>
      {/* Region A — sticky status strip with avatar + city + check-in CTA */}
      <section class="container-wide pt-6 pb-3 reveal">
        <div class="feed-status">
          <a href="/lounge/app/profile/" class="feed-status__avatar" id="feed-avatar">…</a>
          <div class="feed-status__info">
            <p class="feed-status__hi">Hi, <span id="dash-name">there</span></p>
            <p class="feed-status__sub">
              <span id="dash-city">your city</span>
              <span id="dash-founding" class="feed-status__chip" hidden>Founding</span>
            </p>
          </div>
          <a href="/lounge/app/map/" class="lbtn lbtn-secondary lbtn-sm">I'm at a lounge</a>
        </div>
      </section>

      {/* Region A2 — Personalized hero CTA. Resolves to the highest-priority
          action for this member: upcoming trip, unread DMs, RSVP today,
          haven't checked in this week, etc. Hidden if no relevant action. */}
      <section id="hero-cta-section" class="container-wide pb-3" hidden>
        <a id="hero-cta" class="hero-cta" href="#">
          <div class="hero-cta__icon" id="hero-cta-icon"></div>
          <div class="hero-cta__body">
            <p class="hero-cta__kicker" id="hero-cta-kicker">FOR YOU</p>
            <p class="hero-cta__title" id="hero-cta-title">—</p>
            <p class="hero-cta__sub" id="hero-cta-sub">—</p>
          </div>
          <span class="hero-cta__arrow" aria-hidden="true">→</span>
        </a>
      </section>

      {/* Region B — Live now horizontal strip of currently-checked-in members */}
      <section class="container-wide pb-3">
        <div class="feed-section-head">
          <p class="lounge-label lounge-label--gold" id="live-now-label">Live now</p>
          <a href="/lounge/app/map/" class="feed-section-head__link">Open map →</a>
        </div>
        <div id="live-now-strip" class="live-strip">
          <div class="lounge-empty lounge-empty--inline" style="flex-grow:1;">
            <div class="lounge-empty__art">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />
              </svg>
            </div>
            <h3 class="lounge-empty__title">Nobody's checked in right now.</h3>
            <a href="/lounge/app/map/" class="lbtn lbtn-primary lbtn-sm">Be the first</a>
          </div>
        </div>
      </section>

      {/* Region B2 — Upcoming events in member's city. Hidden if there are none. */}
      <section id="events-section" class="container-wide pb-3" hidden>
        <div class="feed-section-head">
          <p class="lounge-label lounge-label--gold">Upcoming in <span id="events-city">your city</span></p>
          <a href="/lounge/app/events/" class="feed-section-head__link">All events →</a>
        </div>
        <div id="events-strip" class="events-strip"></div>
      </section>

      {/* Region B3 — Flavor matches. Hidden if no matches found. */}
      <section id="match-section" class="container-wide pb-3" hidden>
        <div class="feed-section-head">
          <p class="lounge-label lounge-label--gold">Members you'd vibe with</p>
          <a href="/lounge/app/directory/" class="feed-section-head__link">Browse all →</a>
        </div>
        <div id="match-strip" class="events-strip"></div>
      </section>

      {/* Region C — From the network — chronological activity feed */}
      <section class="container-wide pb-24">
        <div class="feed-section-head">
          <p class="lounge-label">From the network</p>
        </div>
        <div id="feed-list" class="feed-list"></div>
        <div id="feed-empty" hidden class="lounge-empty">
          <div class="lounge-empty__art">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
              <path d="M28 14 C 22 22, 22 30, 28 38 C 34 46, 34 54, 28 60" fill="none"/>
              <path d="M36 14 C 42 22, 42 30, 36 38 C 30 46, 30 54, 36 60" fill="none"/>
            </svg>
          </div>
          <p class="lounge-empty__kicker">Nothing here yet</p>
          <h3 class="lounge-empty__title">The feed wakes up when members do.</h3>
          <p class="lounge-empty__body">Check in at a venue, declare a trip, or invite a friend — the network feed fills up as soon as things happen.</p>
          <a href="/lounge/app/map/" class="lounge-empty__cta lbtn lbtn-primary lbtn-sm">Explore the map</a>
        </div>
      </section>
    </div>
  </main>
  <LoungeTabBar active="home" />
</BaseLayout>

<style is:global>
  /* Global so dynamically-injected feed cards (innerHTML) get the styling. */
  .lounge-app { min-height: calc(100vh - 80px); background: var(--color-bg); }

  .lounge-app__guard {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lounge-app__guard-eyebrow {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .lounge-dash-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) { .lounge-dash-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; } }

  .lounge-dash-card {
    display: block;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.25rem 1.35rem;
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .lounge-dash-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .lounge-dash-card--soon {
    background: var(--color-bg);
    pointer-events: none;
    opacity: 0.88;
  }
  .lounge-dash-card--primary {
    border-left: 3px solid var(--color-accent);
  }
  .lounge-dash-card__eyebrow {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-burgundy);
    margin: 0 0 0.55rem 0;
  }
  .lounge-dash-card__title {
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin: 0 0 0.4rem 0;
  }
  .lounge-dash-card__body {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-text-soft);
    margin: 0 0 0.85rem 0;
  }
  .lounge-dash-card__cta {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-accent);
  }
  .lounge-dash-card__cta--muted { color: var(--color-text-muted); }

  .lounge-dash-meta {
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1.5rem 1.85rem;
    max-width: 32rem;
  }
  .lounge-dash-meta__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--color-border);
    margin: 0;
    font-size: 0.92rem;
    color: var(--color-text);
  }
  .lounge-dash-meta__row:last-child { border-bottom: 0; }
  .lounge-dash-meta__label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
  }
  .lounge-dash-meta__badge {
    background: var(--color-accent);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    border-radius: 3px;
  }

  /* ═════════════════════════════════════════════════════════════════════
   * Home feed (P1 #6 redesign)
   * Status strip + Live-now horizontal carousel + chronological feed.
   * ═════════════════════════════════════════════════════════════════════ */

  /* Status strip */
  .feed-status {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-gold-soft, rgba(201, 169, 97, 0.18));
    border-radius: 10px;
  }
  .feed-status__avatar {
    width: 48px; height: 48px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-gold, #c9a961);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    text-decoration: none;
  }
  .feed-status__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .feed-status__avatar .feed-avatar__initials {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 800;
    color: var(--color-gold, #c9a961);
  }
  .feed-status__info { flex-grow: 1; min-width: 0; }
  .feed-status__hi {
    margin: 0;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 800;
    color: var(--color-text);
    line-height: 1.2;
  }
  .feed-status__sub {
    margin: 2px 0 0 0;
    font-size: 12px;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .feed-status__chip {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--color-gold, #c9a961);
    color: var(--color-charcoal, #1a1d2e);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Section heads */
  .feed-section-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin: 20px 0 10px;
  }
  .feed-section-head__link {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-gold, #c9a961);
    text-decoration: none;
  }
  .feed-section-head__link:hover { color: var(--color-gold-hover, #b69649); }

  /* Live-now horizontal strip */
  .live-strip {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .live-strip::-webkit-scrollbar { display: none; }

  /* Hero CTA — personalized action card. Bigger, gold-accented, full width. */
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: linear-gradient(135deg, rgba(201, 169, 97, 0.16), rgba(201, 169, 97, 0.06));
    border: 1px solid rgba(201, 169, 97, 0.45);
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-text);
    transition: transform 0.15s ease, border-color 0.15s ease;
  }
  .hero-cta:hover {
    transform: translateY(-1px);
    border-color: var(--color-gold, #c9a961);
  }
  .hero-cta__icon {
    flex-shrink: 0;
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--color-gold, #c9a961);
    color: var(--color-charcoal, #1a1d2e);
    display: flex; align-items: center; justify-content: center;
  }
  .hero-cta__icon svg {
    width: 22px; height: 22px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .hero-cta__body { flex: 1; min-width: 0; }
  .hero-cta__kicker {
    margin: 0;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold, #c9a961);
  }
  .hero-cta__title {
    margin: 4px 0 2px;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
  }
  .hero-cta__sub {
    margin: 0;
    font-size: 0.82rem;
    color: var(--color-text-soft);
    line-height: 1.4;
  }
  .hero-cta__arrow {
    flex-shrink: 0;
    color: var(--color-gold, #c9a961);
    font-size: 22px;
    font-weight: 700;
  }

  /* Flavor match cards — denser version of the events-strip card */
  .match-card {
    flex: 0 0 200px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 14px;
    text-decoration: none;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    transition: transform 0.15s ease;
  }
  .match-card:hover { transform: translateY(-2px); }
  .match-card__avatar {
    width: 56px; height: 56px;
    border-radius: 50%;
    border: 2px solid var(--color-gold-soft, rgba(201, 169, 97, 0.35));
    background: var(--color-bg);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-text-muted);
  }
  .match-card__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .match-card__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .match-card__overlap {
    margin: 0;
    font-size: 0.74rem;
    color: var(--color-gold, #c9a961);
    line-height: 1.35;
  }
  .match-card__city {
    margin: 0;
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  /* Upcoming events strip — horizontal scrollable cards, mirrors live-strip layout */
  .events-strip {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 8px;
    margin-top: 6px;
  }
  .events-strip::-webkit-scrollbar { display: none; }
  .events-strip__card {
    flex: 0 0 240px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-gold, #c9a961);
    border-radius: 8px;
    padding: 12px 14px;
    text-decoration: none;
    color: var(--color-text);
    display: flex; flex-direction: column; gap: 4px;
    transition: transform 0.15s ease;
  }
  .events-strip__card:hover { transform: translateY(-1px); }
  .events-strip__date {
    font-size: 0.7rem; font-weight: 800; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--color-gold, #c9a961);
  }
  .events-strip__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.96rem; font-weight: 700;
    line-height: 1.25;
  }
  .events-strip__venue {
    margin: 0;
    font-size: 0.78rem;
    color: var(--color-text-soft);
  }
  .live-card {
    flex-shrink: 0;
    width: 110px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-gold-soft, rgba(201, 169, 97, 0.18));
    border-radius: 10px;
    padding: 12px 8px 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .live-card:hover { border-color: var(--color-gold, #c9a961); transform: translateY(-1px); }
  .live-card__avatar {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-gold, #c9a961);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .live-card__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .live-card__avatar .feed-avatar__initials {
    font-family: var(--font-display);
    font-size: 16px; font-weight: 800;
    color: var(--color-gold, #c9a961);
  }
  .live-card__name {
    font-size: 12px;
    font-weight: 700;
    line-height: 1.15;
    text-align: center;
    max-width: 96px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .live-card__you {
    display: inline-block;
    margin-left: 4px;
    font-size: 9px;
    font-weight: 700;
    color: var(--color-charcoal, #1a1d2e);
    background: var(--color-gold, #c9a961);
    padding: 1px 5px;
    border-radius: 999px;
    vertical-align: middle;
  }
  .live-card__venue {
    font-size: 11px;
    color: var(--color-burgundy);
    line-height: 1.15;
    text-align: center;
    max-width: 96px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .live-card__city {
    font-size: 9px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .live-strip__empty {
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 16px;
    background: var(--color-bg-soft);
    border: 1px dashed var(--color-gold-soft);
    border-radius: 10px;
  }
  .live-strip__empty p { margin: 0; font-size: 13px; color: var(--color-text-soft); }

  /* Chronological feed */
  .feed-list {
    display: flex;
    flex-direction: column;
  }
  .feed-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 4px;
    border-bottom: 1px solid var(--color-gold-soft, rgba(201, 169, 97, 0.18));
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.15s ease;
  }
  .feed-row:last-child { border-bottom: none; }
  .feed-row:hover { background: rgba(201, 169, 97, 0.04); }
  .feed-row--intro { background: rgba(201, 169, 97, 0.06); padding-left: 12px; padding-right: 12px; border-left: 3px solid var(--color-gold); border-radius: 6px; margin-bottom: 6px; }

  .feed-row__avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-bg-soft);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .feed-row__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .feed-row__avatar .feed-avatar__initials {
    font-family: var(--font-display);
    font-size: 13px; font-weight: 800;
    color: var(--color-gold, #c9a961);
  }
  .feed-row__body { flex-grow: 1; min-width: 0; }
  .feed-row__line {
    margin: 0;
    font-size: 14px;
    line-height: 1.4;
    color: var(--color-text);
  }
  .feed-row__line strong { font-weight: 700; }
  .feed-row__muted { color: var(--color-text-muted); font-weight: 400; }
  .feed-row__meta {
    margin: 2px 0 0 0;
    font-size: 11px;
    color: var(--color-text-muted);
  }
  .feed-row__pill {
    display: inline-block;
    margin-left: 6px;
    padding: 1px 7px;
    border-radius: 999px;
    background: var(--color-gold, #c9a961);
    color: var(--color-charcoal);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    vertical-align: middle;
  }

  .feed-empty {
    padding: 24px;
    text-align: center;
    background: var(--color-bg-soft);
    border: 1px dashed var(--color-gold-soft);
    border-radius: 10px;
  }
  .feed-empty__line {
    margin: 0 0 12px 0;
    font-size: 14px;
    color: var(--color-text-soft);
  }
</style>

<script>
  import { getCurrentUser, getCurrentProfile, getSupabase, touchActive } from "../../../lib/supabase";

  function escapeHtml(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }
  function initials(name: string | null): string {
    if (!name) return "?";
    const parts = name.trim().split(/\s+/);
    return ((parts[0]?.[0] || "") + (parts[1]?.[0] || "")).toUpperCase() || "?";
  }
  function timeAgo(iso: string): string {
    const sec = Math.max(1, Math.floor((Date.now() - new Date(iso).getTime()) / 1000));
    if (sec < 60) return `${sec}s ago`;
    const min = Math.floor(sec / 60);
    if (min < 60) return `${min}m ago`;
    const hr = Math.floor(min / 60);
    if (hr < 24) return `${hr}h ago`;
    const d = Math.floor(hr / 24);
    if (d < 7) return `${d}d ago`;
    return new Date(iso).toLocaleDateString("en-US", { month: "short", day: "numeric" });
  }
  function dateRange(arrive: string, depart: string): string {
    const a = new Date(arrive + "T00:00:00");
    const d = new Date(depart + "T00:00:00");
    const sameMonth = a.getMonth() === d.getMonth() && a.getFullYear() === d.getFullYear();
    if (sameMonth) {
      return `${a.toLocaleDateString("en-US", { month: "short" })} ${a.getDate()}–${d.getDate()}`;
    }
    const fmt = (x: Date) => x.toLocaleDateString("en-US", { month: "short", day: "numeric" });
    return `${fmt(a)} – ${fmt(d)}`;
  }
  function avatarHtml(profile: { display_name?: string | null; avatar_url?: string | null } | null): string {
    if (!profile) return `<span class="feed-avatar__initials">?</span>`;
    if (profile.avatar_url) return `<img src="${escapeHtml(profile.avatar_url)}" alt="" />`;
    return `<span class="feed-avatar__initials">${initials(profile.display_name || null)}</span>`;
  }

  async function loadAndRenderFeed(userId: string): Promise<void> {
    const supabase = getSupabase();
    const now = new Date().toISOString();
    const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
    const today = now.slice(0, 10);

    const [
      { data: checkins },
      { data: trips },
      { data: joins },
      { data: introsToMe },
    ] = await Promise.all([
      supabase
        .from("checkins")
        .select("id, member_id, checked_in_at, expires_at, message, profile:member_id(display_name, avatar_url), lounge:lounge_id(name, city)")
        .gt("expires_at", now)
        .order("checked_in_at", { ascending: false })
        .limit(40),
      supabase
        .from("travel_plans")
        .select("id, member_id, city, country_code, arrive_date, depart_date, notes, created_at, profile:member_id(display_name, avatar_url)")
        .gte("depart_date", today)
        .order("created_at", { ascending: false })
        .limit(20),
      supabase
        .from("profiles")
        .select("id, display_name, avatar_url, city, joined_at, is_founding")
        .gte("joined_at", sevenDaysAgo)
        .order("joined_at", { ascending: false })
        .limit(10),
      supabase
        .from("introductions")
        .select("id, from_member_id, intro_message, context, accepted, created_at, profile:from_member_id(display_name, avatar_url)")
        .eq("to_member_id", userId)
        .is("accepted", null)
        .order("created_at", { ascending: false })
        .limit(10),
    ]);

    // ── LIVE NOW strip ─────────────────────────────────────────────────────
    const liveStrip = document.getElementById("live-now-strip") as HTMLElement;
    const liveLabel = document.getElementById("live-now-label") as HTMLElement;
    const liveRows = (checkins as any[]) || [];
    if (liveLabel) liveLabel.textContent = `Live now · ${liveRows.length} checked in`;
    if (liveStrip) {
      if (liveRows.length === 0) {
        liveStrip.innerHTML = `
          <div class="lounge-empty lounge-empty--inline" style="flex-grow:1;">
            <div class="lounge-empty__art">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" />
              </svg>
            </div>
            <h3 class="lounge-empty__title">Nobody's checked in right now.</h3>
            <a href="/lounge/app/map/" class="lbtn lbtn-primary lbtn-sm">Be the first</a>
          </div>`;
      } else {
        liveStrip.innerHTML = liveRows.map((c) => {
          const name = escapeHtml(c.profile?.display_name || "Member");
          const venue = escapeHtml(c.lounge?.name || "");
          const city = escapeHtml(c.lounge?.city || "");
          const meTag = c.member_id === userId ? '<span class="live-card__you">you</span>' : "";
          return `
            <a class="live-card" href="/lounge/app/map/${c.lounge?.city ? `?city=${encodeURIComponent(c.lounge.city)}` : ""}">
              <div class="live-card__avatar">${avatarHtml(c.profile)}</div>
              <div class="live-card__name">${name}${meTag}</div>
              <div class="live-card__venue">${venue}</div>
              <div class="live-card__city">${city}</div>
            </a>`;
        }).join("");
      }
    }

    // ── FEED — union of entry types, sorted by recency ────────────────────
    type Entry = { ts: string; html: string };
    const entries: Entry[] = [];

    for (const c of ((checkins as any[]) || []).slice(0, 12)) {
      if (c.member_id === userId) continue;
      const name = escapeHtml(c.profile?.display_name || "Member");
      const venue = c.lounge?.name ? `${escapeHtml(c.lounge.name)}${c.lounge.city ? ` <span class="feed-row__muted">· ${escapeHtml(c.lounge.city)}</span>` : ""}` : "the lounge";
      entries.push({
        ts: c.checked_in_at,
        html: `
          <a class="feed-row" href="/lounge/app/member/?id=${c.member_id}">
            <div class="feed-row__avatar">${avatarHtml(c.profile)}</div>
            <div class="feed-row__body">
              <p class="feed-row__line"><strong>${name}</strong> checked in at ${venue}</p>
              <p class="feed-row__meta">${timeAgo(c.checked_in_at)}</p>
            </div>
          </a>`,
      });
    }

    for (const t of ((trips as any[]) || [])) {
      if (t.member_id === userId) continue;
      const name = escapeHtml(t.profile?.display_name || "Member");
      const city = escapeHtml(t.city);
      const range = dateRange(t.arrive_date, t.depart_date);
      entries.push({
        ts: t.created_at,
        html: `
          <a class="feed-row" href="/lounge/app/member/?id=${t.member_id}">
            <div class="feed-row__avatar">${avatarHtml(t.profile)}</div>
            <div class="feed-row__body">
              <p class="feed-row__line"><strong>${name}</strong> is coming to ${city} — ${range}</p>
              <p class="feed-row__meta">${timeAgo(t.created_at)}</p>
            </div>
          </a>`,
      });
    }

    for (const j of ((joins as any[]) || [])) {
      if (j.id === userId) continue;
      const name = escapeHtml(j.display_name || "Member");
      const city = j.city ? `from ${escapeHtml(j.city)}` : "";
      const foundingPill = j.is_founding ? '<span class="feed-row__pill">Founding</span>' : "";
      entries.push({
        ts: j.joined_at,
        html: `
          <a class="feed-row" href="/lounge/app/member/?id=${j.id}">
            <div class="feed-row__avatar">${avatarHtml(j)}</div>
            <div class="feed-row__body">
              <p class="feed-row__line"><strong>${name}</strong> just joined ${city} ${foundingPill}</p>
              <p class="feed-row__meta">${timeAgo(j.joined_at)}</p>
            </div>
          </a>`,
      });
    }

    for (const i of ((introsToMe as any[]) || [])) {
      const name = escapeHtml(i.profile?.display_name || "Member");
      entries.push({
        ts: i.created_at,
        html: `
          <a class="feed-row feed-row--intro" href="/lounge/app/inbox/">
            <div class="feed-row__avatar">${avatarHtml(i.profile)}</div>
            <div class="feed-row__body">
              <p class="feed-row__line"><strong>${name}</strong> asked to meet you</p>
              <p class="feed-row__meta">Tap to accept or decline · ${timeAgo(i.created_at)}</p>
            </div>
          </a>`,
      });
    }

    entries.sort((a, b) => new Date(b.ts).getTime() - new Date(a.ts).getTime());

    const feedList = document.getElementById("feed-list") as HTMLElement;
    const feedEmpty = document.getElementById("feed-empty") as HTMLElement;
    if (feedList && feedEmpty) {
      if (entries.length === 0) {
        feedList.innerHTML = "";
        feedEmpty.hidden = false;
      } else {
        feedEmpty.hidden = true;
        feedList.innerHTML = entries.slice(0, 30).map((e) => e.html).join("");
      }
    }
  }

  async function init() {
    // Capture referral code from ?ref=CODE on any /lounge/app/ entry — works
    // even when a creator shares the bare lounge subdomain root instead of
    // /signup. Stored in localStorage and applied by the welcome flow on
    // first visit.
    try {
      const ref = new URLSearchParams(window.location.search).get("ref");
      if (ref && /^[A-Za-z0-9_-]{2,32}$/.test(ref)) {
        localStorage.setItem("lounge_referral_code", ref.toUpperCase());
      }
    } catch {}

    const user = await getCurrentUser();
    if (!user) {
      window.location.href = "/lounge/login/";
      return;
    }

    const profile = await getCurrentProfile();
    if (!profile) {
      window.location.href = "/lounge/app/welcome/";
      return;
    }
    // First-time member — profile row exists but city not set yet → route through welcome
    if (!profile.city) {
      window.location.href = "/lounge/app/welcome/";
      return;
    }

    // Touch last_active_at in the background
    touchActive().catch(() => {});

    // Region A — status strip
    const nameEl = document.getElementById("dash-name");
    if (nameEl) nameEl.textContent = profile.display_name || "Member";
    const cityEl = document.getElementById("dash-city");
    if (cityEl) cityEl.textContent = profile.city || "Set your city";
    if (profile.is_founding) {
      const chip = document.getElementById("dash-founding");
      if (chip) chip.hidden = false;
    }
    const avEl = document.getElementById("feed-avatar");
    if (avEl) avEl.innerHTML = avatarHtml(profile as any);

    await Promise.all([
      loadAndRenderFeed(user.id),
      loadUpcomingEvents(profile?.city || null),
      loadHeroCta(user.id, profile),
      loadFlavorMatches(user.id, profile),
    ]);

    const guard = document.getElementById("lounge-guard");
    const content = document.getElementById("lounge-content");
    if (guard) guard.style.display = "none";
    if (content) content.hidden = false;
  }

  // ── Hero CTA — picks the highest-priority action for THIS member right now
  // ───────────────────────────────────────────────────────────────────────
  // Priority order:
  //   1. Unread direct messages
  //   2. Trip in next 14 days with locals there
  //   3. Event in your city in next 7 days you haven't RSVP'd
  //   4. Haven't checked in in last 7 days
  //   5. (Fallback) Cohort growth in your city
  async function loadHeroCta(userId: string, profile: any): Promise<void> {
    const section = document.getElementById("hero-cta-section") as HTMLElement;
    const cta = document.getElementById("hero-cta") as HTMLAnchorElement;
    const iconEl = document.getElementById("hero-cta-icon") as HTMLElement;
    const kickerEl = document.getElementById("hero-cta-kicker") as HTMLElement;
    const titleEl = document.getElementById("hero-cta-title") as HTMLElement;
    const subEl = document.getElementById("hero-cta-sub") as HTMLElement;
    if (!section || !cta) return;

    const supabase = getSupabase();
    const now = new Date();
    const myCity = (profile?.city || "").trim();

    const set = (href: string, kicker: string, title: string, sub: string, iconSvg: string) => {
      cta.href = href;
      iconEl.innerHTML = iconSvg;
      kickerEl.textContent = kicker;
      titleEl.textContent = title;
      subEl.textContent = sub;
      section.hidden = false;
    };

    // 1. Unread DMs
    try {
      const { count: unreadCount } = await supabase
        .from("direct_messages")
        .select("id", { count: "exact", head: true })
        .eq("recipient_id", userId)
        .is("read_at", null);
      if (unreadCount && unreadCount > 0) {
        set(
          "/lounge/app/messages/",
          "Inbox",
          `${unreadCount} unread message${unreadCount === 1 ? "" : "s"}`,
          "Tap to read and reply.",
          `<svg viewBox="0 0 24 24"><path d="M4 4h16v12H5.5L4 17.5V4Z"/></svg>`,
        );
        return;
      }
    } catch {}

    // 2. Your upcoming trip — show if leaving in 14 days
    try {
      const today = now.toISOString().slice(0, 10);
      const horizon = new Date(Date.now() + 14 * 86400000).toISOString().slice(0, 10);
      const { data: myTrips } = await supabase
        .from("travel_plans")
        .select("city, arrive_date, depart_date")
        .eq("member_id", userId)
        .gte("arrive_date", today)
        .lte("arrive_date", horizon)
        .order("arrive_date", { ascending: true })
        .limit(1);
      const trip = (myTrips as any[])?.[0];
      if (trip) {
        const days = Math.max(0, Math.round((new Date(trip.arrive_date + "T00:00:00").getTime() - Date.now()) / 86400000));
        // Count locals (hosts) in destination city
        const { count: hostCount } = await supabase
          .from("profiles")
          .select("id", { count: "exact", head: true })
          .ilike("city", trip.city)
          .eq("is_host", true);
        set(
          `/lounge/app/directory/?city=${encodeURIComponent(trip.city)}`,
          "Your trip",
          `You're going to ${trip.city} in ${days === 0 ? "today" : days + " day" + (days === 1 ? "" : "s")}`,
          hostCount && hostCount > 0
            ? `${hostCount} host${hostCount === 1 ? "" : "s"} there. Send an intro before you land.`
            : "Browse members in that city.",
          `<svg viewBox="0 0 24 24"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.7c-.2.4 0 .8.3 1.1l5.4 4.3-1.5 4.5L4 18l2 2 2-1.8 4.5-1.5 4.3 5.4c.3.3.7.5 1.1.3l.7-.3c.4-.2.6-.6.5-1.1Z"/></svg>`,
        );
        return;
      }
    } catch {}

    // 3. Event in your city in next 7 days (you haven't RSVP'd)
    if (myCity) {
      try {
        const sevenDays = new Date(Date.now() + 7 * 86400000).toISOString();
        const { data: events } = await supabase
          .from("cigar_events")
          .select("id, title, city, start_at")
          .not("verified_at", "is", null)
          .ilike("city", myCity)
          .gte("start_at", now.toISOString())
          .lte("start_at", sevenDays)
          .order("start_at", { ascending: true })
          .limit(1);
        const ev = (events as any[])?.[0];
        if (ev) {
          // Check if user has already RSVP'd
          const { data: myRsvp } = await supabase
            .from("event_rsvps")
            .select("id")
            .eq("event_id", ev.id)
            .eq("member_id", userId)
            .maybeSingle();
          if (!myRsvp) {
            const d = new Date(ev.start_at);
            const when = d.toLocaleDateString("en-US", { weekday: "long" });
            set(
              `/lounge/app/events/?id=${ev.id}`,
              "Event this week",
              ev.title,
              `${when} in ${ev.city}. Tap to RSVP.`,
              `<svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
            );
            return;
          }
        }
      } catch {}
    }

    // 4. Haven't checked in in 7 days — nudge to check in
    try {
      const sevenAgo = new Date(Date.now() - 7 * 86400000).toISOString();
      const { count: recent } = await supabase
        .from("checkins")
        .select("id", { count: "exact", head: true })
        .eq("member_id", userId)
        .gte("checked_in_at", sevenAgo);
      if (!recent || recent === 0) {
        set(
          "/lounge/app/map/",
          "Where are you smoking?",
          "Check in tonight",
          "Members in your city see you and can drop by. 90 minutes of presence.",
          `<svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
        );
        return;
      }
    } catch {}

    // No CTA worth surfacing — hide the section.
    section.hidden = true;
  }

  // ── Flavor matches — members in your city or coming to your city who share
  // your favorite brands or flavor notes. Hides if you have no flavor data or
  // no matches.
  async function loadFlavorMatches(userId: string, profile: any): Promise<void> {
    const section = document.getElementById("match-section") as HTMLElement;
    const strip = document.getElementById("match-strip") as HTMLElement;
    if (!section || !strip || !profile) return;

    const myBrands: string[] = profile.favorite_brands || [];
    const myNotes: string[] = profile.flavor_notes || [];
    if (myBrands.length === 0 && myNotes.length === 0) {
      section.hidden = true;
      return;
    }

    const supabase = getSupabase();
    // Pull up to 60 candidates with flavor data; we'll score client-side.
    const { data: candidates } = await supabase
      .from("profiles")
      .select("id, display_name, avatar_url, city, favorite_brands, flavor_notes")
      .neq("id", userId)
      .or(
        `favorite_brands.ov.{${myBrands.map((b) => '"' + b.replace(/"/g, '\\"') + '"').join(",")}},` +
        `flavor_notes.ov.{${myNotes.map((n) => '"' + n.replace(/"/g, '\\"') + '"').join(",")}}`
      )
      .limit(60);

    type Match = { id: string; display_name: string; avatar_url: string | null; city: string | null; overlap: string };
    const matches: Match[] = [];
    for (const c of (candidates as any[]) || []) {
      const sharedBrands = (c.favorite_brands || []).filter((b: string) => myBrands.includes(b));
      const sharedNotes = (c.flavor_notes || []).filter((n: string) => myNotes.includes(n));
      let overlap = "";
      if (sharedBrands.length > 0) {
        overlap = `Loves ${sharedBrands.slice(0, 2).join(" & ")}`;
      } else if (sharedNotes.length >= 2) {
        overlap = `${sharedNotes.slice(0, 2).join(" & ").toLowerCase()} notes`;
      } else if (sharedNotes.length === 1) {
        overlap = `${sharedNotes[0].toLowerCase()} notes`;
      }
      if (overlap) matches.push({ id: c.id, display_name: c.display_name, avatar_url: c.avatar_url, city: c.city, overlap });
    }
    if (matches.length === 0) {
      section.hidden = true;
      return;
    }

    section.hidden = false;
    strip.innerHTML = matches
      .slice(0, 12)
      .map((m) => {
        const av = m.avatar_url
          ? `<img src="${escapeHtml(m.avatar_url)}" alt="" />`
          : initials(m.display_name);
        return `
          <a class="match-card" href="/lounge/app/member/?id=${m.id}">
            <div class="match-card__avatar">${av}</div>
            <p class="match-card__name">${escapeHtml(m.display_name || "Member")}</p>
            <p class="match-card__overlap">${escapeHtml(m.overlap)}</p>
            ${m.city ? `<p class="match-card__city">${escapeHtml(m.city)}</p>` : ""}
          </a>
        `;
      })
      .join("");
  }

  // Upcoming events in the member's city — horizontal strip. Hides if none.
  async function loadUpcomingEvents(myCity: string | null): Promise<void> {
    const section = document.getElementById("events-section") as HTMLElement | null;
    const strip = document.getElementById("events-strip") as HTMLElement | null;
    const cityEl = document.getElementById("events-city") as HTMLElement | null;
    if (!section || !strip) return;

    const supabase = getSupabase();
    const nowIso = new Date().toISOString();

    // Try city-specific first; if none, fall back to any upcoming events globally.
    let q = supabase
      .from("cigar_events")
      .select("id, title, city, start_at, venue:venue_id(name)")
      .not("verified_at", "is", null)
      .gte("start_at", nowIso)
      .order("start_at", { ascending: true })
      .limit(8);
    if (myCity) q = q.ilike("city", myCity);
    let { data: events } = await q;

    let scope = "your city";
    if (myCity) scope = myCity;
    if (!events || events.length === 0) {
      // Fallback: show any upcoming globally
      const { data: anywhere } = await supabase
        .from("cigar_events")
        .select("id, title, city, start_at, venue:venue_id(name)")
        .not("verified_at", "is", null)
        .gte("start_at", nowIso)
        .order("start_at", { ascending: true })
        .limit(6);
      events = anywhere || [];
      scope = "the network";
    }

    if (events.length === 0) {
      section.hidden = true;
      return;
    }
    if (cityEl) cityEl.textContent = scope;
    section.hidden = false;

    strip.innerHTML = events
      .map((e: any) => {
        const d = new Date(e.start_at);
        const dateStr = d.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" }).toUpperCase();
        const venueName = e.venue?.name || e.city;
        return `
          <a class="events-strip__card" href="/lounge/app/events/?id=${e.id}">
            <p class="events-strip__date">${dateStr}</p>
            <h3 class="events-strip__title">${escapeHtml(e.title)}</h3>
            <p class="events-strip__venue">${escapeHtml(venueName)}${e.city !== venueName ? " · " + escapeHtml(e.city) : ""}</p>
          </a>
        `;
      })
      .join("");
  }

  document.addEventListener("astro:page-load", init);
  init();
</script>
