---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import LoungeHeader from "../../../../components/lounge/LoungeHeader.astro";
import LoungeTabBar from "../../../../components/lounge/LoungeTabBar.astro";
---

<BaseLayout
  title="Members — The Lounge"
  description="Browse the founding cohort of The Lounge."
  noIndex
>
  <LoungeHeader active="directory" />

  <main class="lounge-app">
    <div id="lounge-guard" class="lskel-page">
      <p class="lskel-kicker">Loading members</p>
      <span class="lskel lskel--line-xl" style="width:280px;margin-bottom:10px;"></span>
      <span class="lskel lskel--line" style="width:60%;margin-bottom:24px;"></span>

      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;">
        <span class="lskel lskel--pill" style="width:120px;"></span>
        <span class="lskel lskel--pill" style="width:90px;"></span>
        <span class="lskel lskel--pill" style="width:140px;"></span>
      </div>

      <div class="lskel-grid">
        <span class="lskel lskel--card-tall"></span>
        <span class="lskel lskel--card-tall"></span>
        <span class="lskel lskel--card-tall"></span>
        <span class="lskel lskel--card-tall"></span>
        <span class="lskel lskel--card-tall"></span>
        <span class="lskel lskel--card-tall"></span>
      </div>
    </div>

    <div id="lounge-content" hidden>
      <section class="container-wide pt-8 md:pt-12 pb-4 reveal">
        <p class="section-eyebrow">The Lounge · Discover</p>
        <h1 class="font-display text-3xl md:text-5xl leading-[1.05] tracking-tight mt-2">
          Who you should meet.
        </h1>
        <p class="mt-2 text-[color:var(--color-text-soft)] max-w-2xl text-sm">
          Members picked for you based on city, trips, and what you smoke.
        </p>
      </section>

      {/* Layer 1: Curated picks — horizontal cards with the reason on each */}
      <section id="disc-picks-section" class="container-wide pb-3">
        <div class="feed-section-head">
          <p class="lounge-label lounge-label--gold">Members you should meet</p>
        </div>
        <div id="disc-picks" class="disc-strip">
          <div class="lskel lskel--card-tall" style="flex: 0 0 200px; height: 180px;"></div>
          <div class="lskel lskel--card-tall" style="flex: 0 0 200px; height: 180px;"></div>
          <div class="lskel lskel--card-tall" style="flex: 0 0 200px; height: 180px;"></div>
        </div>
      </section>

      {/* Layer 2: Live & near you */}
      <section id="disc-live-section" class="container-wide pb-3" hidden>
        <div class="feed-section-head">
          <p class="lounge-label lounge-label--gold">Live near you</p>
          <a href="/lounge/app/map/" class="feed-section-head__link">Open map →</a>
        </div>
        <div id="disc-live" class="disc-strip"></div>
      </section>

      {/* Layer 3: Active this week */}
      <section id="disc-recent-section" class="container-wide pb-3" hidden>
        <div class="feed-section-head">
          <p class="lounge-label">Active this week</p>
        </div>
        <div id="disc-recent" class="disc-rows"></div>
      </section>

      {/* Layer 4: Search + full browse */}
      <section class="container-wide pb-24">
        <div class="feed-section-head" style="margin-top: 24px;">
          <p class="lounge-label">Browse everyone</p>
          <button id="disc-toggle-filters" class="feed-section-head__link" type="button">Filters ▾</button>
        </div>
        <div class="lounge-dir-filters" id="disc-filters">
          <label class="lounge-dir-filter">
            <span>Search</span>
            <input id="filter-city" type="search" placeholder="Name or city" autocomplete="off" />
          </label>

          <label class="lounge-dir-filter lounge-dir-filter--check">
            <input id="filter-host" type="checkbox" />
            <span>Hosts only</span>
          </label>

          <label class="lounge-dir-filter lounge-dir-filter--check">
            <input id="filter-founding" type="checkbox" />
            <span>Founding members</span>
          </label>

          <p id="filter-count" class="lounge-dir-count">—</p>
        </div>

        <div id="lounge-dir-grid" class="lounge-dir-grid"></div>
        <div id="lounge-dir-empty" hidden class="lounge-empty">
          <div class="lounge-empty__art">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" />
              <path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </div>
          <p class="lounge-empty__kicker">No matches</p>
          <h3 class="lounge-empty__title">Nobody fits those filters yet.</h3>
          <p class="lounge-empty__body">Loosen the filters, or invite a friend in your city — the cohort grows one cigar at a time.</p>
        </div>
      </section>
    </div>
  </main>
  <LoungeTabBar active="members" />
</BaseLayout>

<style is:global>
  /* Global so dynamically-injected cards (innerHTML) get the styling. */
  .lounge-app { min-height: calc(100vh - 80px); background: var(--color-bg); }

  .lounge-app__guard {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lounge-app__guard-eyebrow {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* ── Discover surface (curated picks + live + recent) ─────────────────── */
  .feed-section-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 8px;
  }
  .feed-section-head__link {
    background: none; border: none; padding: 0;
    font: inherit; color: var(--color-gold, #c9a961);
    text-decoration: underline; cursor: pointer;
    font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.06em;
  }
  .disc-strip {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 8px;
  }
  .disc-strip::-webkit-scrollbar { display: none; }
  .disc-card {
    flex: 0 0 200px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-gold, #c9a961);
    border-radius: 10px;
    padding: 14px;
    text-decoration: none;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    transition: transform 0.15s ease;
  }
  .disc-card:hover { transform: translateY(-2px); }
  .disc-card__avatar {
    width: 56px; height: 56px;
    border-radius: 50%;
    border: 2px solid var(--color-gold-soft, rgba(201, 169, 97, 0.45));
    background: var(--color-bg);
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-text-muted);
  }
  .disc-card__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .disc-card__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.96rem;
    font-weight: 700;
    line-height: 1.2;
  }
  .disc-card__reason {
    margin: 0;
    font-size: 0.74rem;
    color: var(--color-gold, #c9a961);
    line-height: 1.35;
    font-weight: 600;
  }
  .disc-card__city {
    margin: 0;
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }
  .disc-rows {
    display: flex; flex-direction: column; gap: 6px;
  }
  .disc-row {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
  }
  .disc-row__avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 0.8rem; font-weight: 800;
    color: var(--color-text-muted);
  }
  .disc-row__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .disc-row__main { flex: 1; min-width: 0; }
  .disc-row__name {
    margin: 0; font-weight: 700; font-size: 0.92rem;
    color: var(--color-text);
  }
  .disc-row__meta {
    margin: 2px 0 0; font-size: 0.78rem; color: var(--color-text-muted);
  }
  .disc-strip__empty {
    color: var(--color-text-muted); font-size: 0.86rem;
    padding: 12px 0;
  }

  .lounge-dir-filters {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }
  .lounge-dir-filter {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }
  .lounge-dir-filter input[type="text"] {
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    background: #fff;
    font-size: 0.92rem;
    color: var(--color-text);
    text-transform: none;
    letter-spacing: normal;
    min-width: 14rem;
  }
  .lounge-dir-filter input[type="text"]:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }
  .lounge-dir-filter--check {
    flex-direction: row;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.85rem;
    text-transform: none;
    letter-spacing: normal;
    color: var(--color-text);
    cursor: pointer;
  }
  .lounge-dir-filter--check input { accent-color: var(--color-accent); width: 1.05rem; height: 1.05rem; }
  .lounge-dir-count {
    margin-left: auto;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .lounge-dir-grid {
    display: grid;
    /* Denser: 2 columns on phone, 3-4 on tablet, more on desktop */
    grid-template-columns: repeat(auto-fill, minmax(11rem, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }
  @media (min-width: 640px) {
    .lounge-dir-grid {
      grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
      gap: 0.9rem;
    }
  }

  .lounge-dir-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.9rem 1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s ease;
    min-height: 0;
  }
  .lounge-dir-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .lounge-dir-card__top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.55rem;
  }
  .lounge-dir-card__avatar {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    object-fit: cover;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text-muted);
  }
  .lounge-dir-card__avatar img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }
  /* Recency rings — gold = active now, gold-soft = today, none = older */
  .lounge-dir-card__avatar { position: relative; }
  .lounge-dir-card__avatar--now { border: 2px solid var(--color-gold, #c9a961); }
  .lounge-dir-card__avatar--today { border: 2px solid rgba(201, 169, 97, 0.5); }
  .lounge-dir-card__avatar--week { border: 2px solid rgba(201, 169, 97, 0.18); }
  .lounge-dir-card__avatar--older { border: 1px solid var(--color-border); }
  .lounge-dir-card__dot {
    position: absolute;
    bottom: -2px;
    right: -2px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #22c55e;
    border: 2px solid var(--color-bg-soft);
  }
  /* Visual hierarchy — Founding gets a stronger gold left border, Host gets burgundy */
  .lounge-dir-card--founding { border-left: 3px solid var(--color-gold, #c9a961); }
  .lounge-dir-card--host { border-left: 3px solid var(--color-burgundy); }
  .lounge-dir-card__name {
    font-family: var(--font-display);
    font-size: 0.98rem;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-text);
    margin: 0;
  }
  .lounge-dir-card__city {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin: 0.1rem 0 0 0;
  }
  .lounge-dir-card__bio {
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--color-text-soft);
    margin: 0 0 0.6rem 0;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .lounge-dir-card__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }
  .lounge-dir-card__badge {
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.28rem 0.55rem;
    border-radius: 3px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .lounge-dir-card__badge--founding {
    background: var(--color-gold, #c9a961);
    color: var(--color-charcoal, #1a1d2e);
    border-color: var(--color-gold, #c9a961);
  }
  .lounge-dir-card__badge--host {
    background: var(--color-burgundy);
    color: #fff;
    border-color: var(--color-burgundy);
  }

  .lounge-dir-empty {
    margin-top: 2rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 2.5rem;
    text-align: center;
  }
  .lounge-dir-empty__eyebrow {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem 0;
  }
  .lounge-dir-empty__body {
    color: var(--color-text-soft);
    margin: 0;
  }
</style>

<script>
  import { getCurrentUser, getSupabase } from "../../../../lib/supabase";

  type ProfileRow = {
    id: string;
    display_name: string | null;
    city: string | null;
    country_code: string | null;
    bio: string | null;
    avatar_url: string | null;
    is_host: boolean | null;
    is_founding: boolean | null;
    joined_at: string | null;
    last_active_at: string | null;
  };

  type Recency = "now" | "today" | "week" | "older";
  function recencyTier(lastActive: string | null): Recency {
    if (!lastActive) return "older";
    const ageMs = Date.now() - new Date(lastActive).getTime();
    const hour = 60 * 60 * 1000;
    if (ageMs < hour) return "now";
    if (ageMs < 24 * hour) return "today";
    if (ageMs < 7 * 24 * hour) return "week";
    return "older";
  }

  let all: ProfileRow[] = [];

  function initials(name: string | null): string {
    if (!name) return "?";
    const parts = name.trim().split(/\s+/);
    const first = parts[0]?.[0] || "";
    const second = parts[1]?.[0] || "";
    return (first + second).toUpperCase() || "?";
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function renderGrid(rows: ProfileRow[]): void {
    const grid = document.getElementById("lounge-dir-grid");
    const empty = document.getElementById("lounge-dir-empty");
    const countEl = document.getElementById("filter-count");
    if (!grid || !empty || !countEl) return;

    countEl.textContent = `${rows.length} ${rows.length === 1 ? "member" : "members"}`;

    if (rows.length === 0) {
      grid.innerHTML = "";
      empty.hidden = false;
      return;
    }
    empty.hidden = true;

    grid.innerHTML = rows
      .map((p) => {
        const name = escapeHtml(p.display_name || "Member");
        const city = p.city ? escapeHtml(p.city) : "City not set";
        const bio = p.bio ? escapeHtml(p.bio) : "—";
        const avatar = p.avatar_url
          ? `<img src="${escapeHtml(p.avatar_url)}" alt="" loading="lazy" />`
          : initials(p.display_name);
        const tier = recencyTier(p.last_active_at);
        const badges: string[] = [];
        if (p.is_founding)
          badges.push(`<span class="lounge-dir-card__badge lounge-dir-card__badge--founding">Founding</span>`);
        if (p.is_host)
          badges.push(`<span class="lounge-dir-card__badge lounge-dir-card__badge--host">Host</span>`);

        const hierarchy = p.is_founding ? "lounge-dir-card--founding" : p.is_host ? "lounge-dir-card--host" : "";

        return `
          <a class="lounge-dir-card ${hierarchy}" href="/lounge/app/member/?id=${p.id}">
            <div class="lounge-dir-card__top">
              <div class="lounge-dir-card__avatar lounge-dir-card__avatar--${tier}">
                ${avatar}
                ${tier === "now" ? '<span class="lounge-dir-card__dot" aria-label="Active now"></span>' : ""}
              </div>
              <div>
                <h2 class="lounge-dir-card__name">${name}</h2>
                <p class="lounge-dir-card__city">${city}</p>
              </div>
            </div>
            <p class="lounge-dir-card__bio">${bio}</p>
            <div class="lounge-dir-card__badges">${badges.join("")}</div>
          </a>
        `;
      })
      .join("");
  }

  function applyFilters(): void {
    const cityInput = document.getElementById("filter-city") as HTMLInputElement | null;
    const hostInput = document.getElementById("filter-host") as HTMLInputElement | null;
    const foundingInput = document.getElementById("filter-founding") as HTMLInputElement | null;

    const cityNeedle = (cityInput?.value || "").trim().toLowerCase();
    const hostOnly = !!hostInput?.checked;
    const foundingOnly = !!foundingInput?.checked;

    const filtered = all.filter((p) => {
      if (cityNeedle && !(p.city || "").toLowerCase().includes(cityNeedle)) return false;
      if (hostOnly && !p.is_host) return false;
      if (foundingOnly && !p.is_founding) return false;
      return true;
    });

    renderGrid(filtered);
  }

  async function init(): Promise<void> {
    const user = await getCurrentUser();
    if (!user) {
      window.location.href = "/lounge/login/";
      return;
    }

    const supabase = getSupabase();
    const { data, error } = await supabase
      .from("profiles")
      .select("id, display_name, city, country_code, bio, avatar_url, is_host, is_founding, joined_at, last_active_at, favorite_brands, flavor_notes, strength_preference")
      .order("last_active_at", { ascending: false, nullsFirst: false });

    if (error) {
      console.error("[Lounge directory] failed to load profiles:", error);
      all = [];
    } else {
      all = (data as ProfileRow[]) || [];
    }

    renderGrid(all);

    // Wire up filters
    document.getElementById("filter-city")?.addEventListener("input", applyFilters);
    document.getElementById("filter-host")?.addEventListener("change", applyFilters);
    document.getElementById("filter-founding")?.addEventListener("change", applyFilters);

    // Filters drawer toggle
    const filtersEl = document.getElementById("disc-filters") as HTMLElement;
    if (filtersEl) filtersEl.hidden = true;
    document.getElementById("disc-toggle-filters")?.addEventListener("click", () => {
      filtersEl.hidden = !filtersEl.hidden;
    });

    // Load discover layers in parallel
    await Promise.all([
      loadDiscoverPicks(user.id),
      loadDiscoverLive(user.id),
      loadDiscoverRecent(user.id),
    ]);

    const guard = document.getElementById("lounge-guard");
    const content = document.getElementById("lounge-content");
    if (guard) guard.style.display = "none";
    if (content) content.hidden = false;
  }

  // ── Discover Layer 1: Members you should meet ─────────────────────────
  async function loadDiscoverPicks(userId: string): Promise<void> {
    const strip = document.getElementById("disc-picks") as HTMLElement;
    if (!strip) return;
    const supabase = getSupabase();

    // Pull viewer's profile + city for matching
    const me = all.find((p) => p.id === userId);
    if (!me) {
      strip.innerHTML = `<p class="disc-strip__empty">Sign in to get personalized picks.</p>`;
      return;
    }
    const myBrands: string[] = ((me as any).favorite_brands as string[]) || [];
    const myNotes: string[] = ((me as any).flavor_notes as string[]) || [];

    // Build candidate pool with a "reason" attached
    type Pick = {
      id: string;
      display_name: string;
      avatar_url: string | null;
      city: string | null;
      reason: string;
      score: number; // higher = better
    };
    const picks: Record<string, Pick> = {};
    const now = Date.now();

    // Source 1: members in my city, active in last 30 days
    if (me.city) {
      for (const p of all) {
        if (p.id === userId || !p.city) continue;
        if (p.city.toLowerCase() !== me.city.toLowerCase()) continue;
        const lastActive = p.last_active_at ? new Date(p.last_active_at).getTime() : 0;
        const daysAgo = (now - lastActive) / 86400000;
        if (daysAgo > 30) continue;
        picks[p.id] = {
          id: p.id,
          display_name: p.display_name || "Member",
          avatar_url: p.avatar_url,
          city: p.city,
          reason: `Active in ${me.city} this week`,
          score: 100 - daysAgo,
        };
      }
    }

    // Source 2: travel plans into my city in next 30 days
    if (me.city) {
      const today = new Date().toISOString().slice(0, 10);
      const horizon = new Date(now + 30 * 86400000).toISOString().slice(0, 10);
      const { data: incoming } = await supabase
        .from("travel_plans")
        .select("member_id, city, arrive_date, depart_date")
        .ilike("city", me.city)
        .gte("arrive_date", today)
        .lte("arrive_date", horizon);
      for (const t of (incoming as any[]) || []) {
        if (t.member_id === userId) continue;
        const p = all.find((x) => x.id === t.member_id);
        if (!p) continue;
        const days = Math.max(0, Math.round((new Date(t.arrive_date + "T00:00:00").getTime() - now) / 86400000));
        picks[p.id] = {
          id: p.id,
          display_name: p.display_name || "Member",
          avatar_url: p.avatar_url,
          city: p.city,
          reason: days === 0 ? `Visiting today` : `Visiting in ${days} day${days === 1 ? "" : "s"}`,
          score: 200 - days, // visiting members rank higher than locals
        };
      }
    }

    // Source 3: flavor matches with score by overlap
    if (myBrands.length > 0 || myNotes.length > 0) {
      for (const p of all) {
        if (p.id === userId) continue;
        if (picks[p.id]) continue; // already has higher-priority reason
        const theirBrands = ((p as any).favorite_brands as string[]) || [];
        const theirNotes = ((p as any).flavor_notes as string[]) || [];
        const sharedBrands = theirBrands.filter((b) => myBrands.includes(b));
        const sharedNotes = theirNotes.filter((n) => myNotes.includes(n));
        if (sharedBrands.length === 0 && sharedNotes.length < 2) continue;
        const reason = sharedBrands.length > 0
          ? `Loves ${sharedBrands.slice(0, 2).join(" & ")}`
          : `${sharedNotes.slice(0, 2).join(" & ").toLowerCase()} notes`;
        picks[p.id] = {
          id: p.id,
          display_name: p.display_name || "Member",
          avatar_url: p.avatar_url,
          city: p.city,
          reason,
          score: 50 + sharedBrands.length * 10 + sharedNotes.length * 5,
        };
      }
    }

    // Source 4: newcomers in my city (joined in last 30 days)
    if (me.city) {
      for (const p of all) {
        if (p.id === userId || picks[p.id]) continue;
        if (!p.city || p.city.toLowerCase() !== me.city.toLowerCase()) continue;
        if (!p.joined_at) continue;
        const daysAgo = (now - new Date(p.joined_at).getTime()) / 86400000;
        if (daysAgo > 30) continue;
        picks[p.id] = {
          id: p.id,
          display_name: p.display_name || "Member",
          avatar_url: p.avatar_url,
          city: p.city,
          reason: `Just joined from ${p.city}`,
          score: 40 - daysAgo,
        };
      }
    }

    const list = Object.values(picks).sort((a, b) => b.score - a.score).slice(0, 8);

    if (list.length === 0) {
      strip.innerHTML = `
        <div class="disc-strip__empty" style="flex: 1;">
          <p>No personalized picks yet — set your <a href="/lounge/app/profile/" style="color:var(--color-gold);text-decoration:underline;">flavor profile</a>
          and a city to unlock matches.</p>
        </div>
      `;
      return;
    }

    strip.innerHTML = list
      .map((p) => {
        const av = p.avatar_url
          ? `<img src="${escapeHtml(p.avatar_url)}" alt="" />`
          : initialsOf(p.display_name);
        return `
          <a class="disc-card" href="/lounge/app/member/?id=${p.id}">
            <div class="disc-card__avatar">${av}</div>
            <p class="disc-card__name">${escapeHtml(p.display_name)}</p>
            <p class="disc-card__reason">${escapeHtml(p.reason)}</p>
            ${p.city ? `<p class="disc-card__city">${escapeHtml(p.city)}</p>` : ""}
          </a>
        `;
      })
      .join("");
  }

  // ── Discover Layer 2: Live near you (currently checked in) ────────────
  async function loadDiscoverLive(userId: string): Promise<void> {
    const section = document.getElementById("disc-live-section") as HTMLElement;
    const strip = document.getElementById("disc-live") as HTMLElement;
    if (!section || !strip) return;
    const me = all.find((p) => p.id === userId);
    const supabase = getSupabase();
    const nowIso = new Date().toISOString();
    let query = supabase
      .from("checkins")
      .select("id, member_id, message, profile:member_id(display_name, avatar_url, city), lounge:lounge_id(name, city)")
      .gt("expires_at", nowIso)
      .neq("member_id", userId);
    if (me?.city) query = query.eq("profile.city", me.city);
    const { data: checkins } = await query.limit(8);
    const rows = ((checkins as any[]) || []).filter((c) => c.profile && c.lounge);
    if (rows.length === 0) {
      section.hidden = true;
      return;
    }
    section.hidden = false;
    strip.innerHTML = rows
      .map((c: any) => {
        const av = c.profile.avatar_url
          ? `<img src="${escapeHtml(c.profile.avatar_url)}" alt="" />`
          : initialsOf(c.profile.display_name);
        return `
          <a class="disc-card" href="/lounge/app/member/?id=${c.member_id}">
            <div class="disc-card__avatar">${av}</div>
            <p class="disc-card__name">${escapeHtml(c.profile.display_name || "Member")}</p>
            <p class="disc-card__reason">At ${escapeHtml(c.lounge.name)}</p>
            <p class="disc-card__city">${escapeHtml(c.lounge.city)}</p>
          </a>
        `;
      })
      .join("");
  }

  // ── Discover Layer 3: Active this week ────────────────────────────────
  async function loadDiscoverRecent(userId: string): Promise<void> {
    const section = document.getElementById("disc-recent-section") as HTMLElement;
    const rowsEl = document.getElementById("disc-recent") as HTMLElement;
    if (!section || !rowsEl) return;
    const sevenDaysAgo = new Date(Date.now() - 7 * 86400000).toISOString();
    const recent = all.filter(
      (p) => p.id !== userId && p.joined_at && p.joined_at > sevenDaysAgo,
    ).slice(0, 6);
    if (recent.length === 0) {
      section.hidden = true;
      return;
    }
    section.hidden = false;
    rowsEl.innerHTML = recent
      .map((p) => {
        const av = p.avatar_url
          ? `<img src="${escapeHtml(p.avatar_url)}" alt="" />`
          : initialsOf(p.display_name);
        const joined = p.joined_at ? new Date(p.joined_at) : null;
        const daysAgo = joined ? Math.round((Date.now() - joined.getTime()) / 86400000) : 0;
        return `
          <a class="disc-row" href="/lounge/app/member/?id=${p.id}">
            <div class="disc-row__avatar">${av}</div>
            <div class="disc-row__main">
              <p class="disc-row__name">${escapeHtml(p.display_name || "Member")} ${p.is_founding ? `<span style="color:var(--color-gold);font-size:10px;font-weight:800;letter-spacing:0.1em;">★ FOUNDING</span>` : ""}</p>
              <p class="disc-row__meta">Joined ${daysAgo === 0 ? "today" : daysAgo + " day" + (daysAgo === 1 ? "" : "s") + " ago"}${p.city ? " · " + escapeHtml(p.city) : ""}</p>
            </div>
          </a>
        `;
      })
      .join("");
  }

  function initialsOf(name: string | null): string {
    return `<span style="font-size: 1.1rem;">${initials(name)}</span>`;
  }

  document.addEventListener("astro:page-load", init);
  init();
</script>
