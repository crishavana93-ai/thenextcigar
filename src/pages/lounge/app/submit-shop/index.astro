---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import LoungeHeader from "../../../../components/lounge/LoungeHeader.astro";
import LoungeTabBar from "../../../../components/lounge/LoungeTabBar.astro";
---

<BaseLayout title="Submit a cigar shop — The Lounge" noIndex>
  <LoungeHeader active="map" />

  <main class="lounge-app">
    <div id="lounge-guard" class="lounge-app__guard">
      <p class="lounge-app__guard-eyebrow">Loading…</p>
    </div>

    <div id="lounge-content" hidden>
      <section class="container-narrow pt-6 pb-3 reveal">
        <p class="lounge-label">Community contribution</p>
        <h1 class="lounge-h1" style="margin-top:4px;">Submit a cigar shop.</h1>
        <p class="lounge-sub" style="margin-top:6px;">
          Know a shop or lounge that's missing from our map? In countries like
          Germany, Spain, and Italy, half the great spots don't show up on
          Google. Submit it here and I'll review within 24h — if it checks out
          it goes live on the map for everyone.
        </p>
      </section>

      <section class="container-narrow pb-24">
        <form id="submit-shop-form" class="ss-form">
          <label class="ss-row">
            <span class="ss-label">Shop / lounge name <em class="ss-req">*</em></span>
            <input type="text" name="shop_name" required maxlength="120"
              placeholder="e.g. Zigarrenhaus Heinhold" />
          </label>

          <div class="ss-cols">
            <label class="ss-row">
              <span class="ss-label">City <em class="ss-req">*</em></span>
              <input type="text" name="city" required maxlength="60"
                placeholder="Berlin" />
            </label>
            <label class="ss-row">
              <span class="ss-label">Country <em class="ss-req">*</em></span>
              <input type="text" name="country" required maxlength="60"
                list="ss-country-list" placeholder="Germany" />
              <datalist id="ss-country-list">
                <option value="Germany"></option>
                <option value="Spain"></option>
                <option value="Italy"></option>
                <option value="France"></option>
                <option value="United Kingdom"></option>
                <option value="Switzerland"></option>
                <option value="Austria"></option>
                <option value="Netherlands"></option>
                <option value="Belgium"></option>
                <option value="Denmark"></option>
                <option value="Sweden"></option>
                <option value="Norway"></option>
                <option value="Finland"></option>
                <option value="Portugal"></option>
                <option value="Greece"></option>
                <option value="Poland"></option>
                <option value="Czech Republic"></option>
                <option value="United States"></option>
                <option value="Canada"></option>
                <option value="Mexico"></option>
                <option value="Cuba"></option>
                <option value="Dominican Republic"></option>
                <option value="Nicaragua"></option>
                <option value="Honduras"></option>
                <option value="Brazil"></option>
                <option value="Argentina"></option>
                <option value="Japan"></option>
                <option value="Hong Kong"></option>
                <option value="Singapore"></option>
                <option value="United Arab Emirates"></option>
                <option value="Australia"></option>
              </datalist>
            </label>
          </div>

          <label class="ss-row">
            <span class="ss-label">Address</span>
            <input type="text" name="address" maxlength="200"
              placeholder="Friedrichstraße 123, 10117 Berlin" />
            <span class="ss-hint">Optional but helps a lot. Copy from Google Maps if you have it.</span>
          </label>

          <fieldset class="ss-row ss-fieldset">
            <legend class="ss-label">Can you smoke there or nearby? <em class="ss-req">*</em></legend>
            <div class="ss-radio-grid">
              <label class="ss-radio">
                <input type="radio" name="can_smoke" value="yes" required />
                <span><strong>Yes</strong> — you can smoke on-site (lounge/club)</span>
              </label>
              <label class="ss-radio">
                <input type="radio" name="can_smoke" value="outside" />
                <span><strong>Outside only</strong> — terrace, courtyard, or just outside</span>
              </label>
              <label class="ss-radio">
                <input type="radio" name="can_smoke" value="no" />
                <span><strong>No</strong> — retail only, no smoking on-site</span>
              </label>
              <label class="ss-radio">
                <input type="radio" name="can_smoke" value="unknown" />
                <span>Not sure</span>
              </label>
            </div>
          </fieldset>

          <label class="ss-row">
            <span class="ss-label">Anything else worth knowing?</span>
            <textarea name="notes" rows="3" maxlength="500"
              placeholder="e.g. 'Huge Cuban selection. Knowledgeable owner. Opens 11am, closed Sundays.'"></textarea>
            <span class="ss-hint">Optional — perks, hours, vibe, what makes it worth a visit.</span>
          </label>

          <button type="submit" id="ss-submit" class="lbtn lbtn-primary lbtn-block">
            Submit shop
          </button>
          <p id="ss-status" class="ss-status" hidden></p>
        </form>

        <div id="ss-success" hidden class="ss-success">
          <div class="ss-success__art">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <p class="ss-success__kicker">Submitted</p>
          <h3 class="ss-success__title">Thanks — I'll review within 24 hours.</h3>
          <p class="ss-success__body">
            If it checks out, the shop goes live on the map. You'll get an email
            when it's published so you can see your contribution.
          </p>
          <div class="ss-success__actions">
            <button type="button" id="ss-another" class="lbtn lbtn-secondary lbtn-sm">
              Submit another
            </button>
            <a href="/lounge/app/map/" class="lbtn lbtn-primary lbtn-sm">Back to the map</a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <LoungeTabBar />
</BaseLayout>

<style is:global>
  .container-narrow { max-width: 560px; margin: 0 auto; padding-inline: 1rem; }
  .ss-form { display: flex; flex-direction: column; gap: 16px; }
  .ss-row { display: flex; flex-direction: column; gap: 4px; }
  .ss-fieldset { border: 1px solid var(--color-gold-soft, rgba(201,169,97,0.18)); border-radius: 10px; padding: 12px 14px; }
  .ss-label {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--color-text-soft);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .ss-req { color: var(--color-gold, #c9a961); font-style: normal; }
  .ss-row input[type="text"],
  .ss-row textarea {
    width: 100%;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid var(--color-gold-soft, rgba(201,169,97,0.25));
    background: var(--color-bg-soft, #fafaf7);
    color: var(--color-text, #1a1d2e);
    font-family: Georgia, serif;
    font-size: 15px;
    line-height: 1.4;
  }
  .ss-row input:focus, .ss-row textarea:focus {
    outline: none;
    border-color: var(--color-gold, #c9a961);
    box-shadow: 0 0 0 3px rgba(201, 169, 97, 0.15);
  }
  .ss-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 480px) { .ss-cols { grid-template-columns: 1fr; } }
  .ss-hint {
    font-size: 0.72rem;
    color: var(--color-text-muted, #8b8780);
    margin-top: 2px;
  }
  .ss-radio-grid { display: flex; flex-direction: column; gap: 8px; margin-top: 8px; }
  .ss-radio {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background 0.12s ease, border-color 0.12s ease;
    font-size: 14px;
  }
  .ss-radio:hover { background: rgba(201, 169, 97, 0.06); }
  .ss-radio input[type="radio"] { margin-top: 3px; accent-color: var(--color-gold, #c9a961); }
  .ss-radio input[type="radio"]:checked + span {
    color: var(--color-text, #1a1d2e);
  }
  .ss-radio:has(input:checked) {
    background: rgba(201, 169, 97, 0.10);
    border-color: rgba(201, 169, 97, 0.4);
  }
  .lbtn-block { width: 100%; justify-content: center; }
  .ss-status {
    margin-top: 8px;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 0.85rem;
    background: rgba(255, 99, 71, 0.08);
    color: #c63a2a;
    border: 1px solid rgba(198, 58, 42, 0.2);
  }
  .ss-success {
    text-align: center;
    padding: 32px 20px;
    border: 1px solid var(--color-gold-soft, rgba(201,169,97,0.25));
    border-radius: 14px;
    background: var(--color-bg-soft, #fafaf7);
  }
  .ss-success__art {
    width: 64px; height: 64px; margin: 0 auto 16px;
    background: rgba(201, 169, 97, 0.16);
    color: var(--color-gold, #c9a961);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .ss-success__art svg { width: 32px; height: 32px; }
  .ss-success__kicker {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-gold, #c9a961);
    margin: 0 0 6px;
  }
  .ss-success__title {
    margin: 0 0 8px;
    font-family: Georgia, serif;
    font-size: 1.3rem;
    color: var(--color-text, #1a1d2e);
  }
  .ss-success__body {
    margin: 0 auto 20px;
    max-width: 32rem;
    color: var(--color-text-soft);
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .ss-success__actions {
    display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;
  }
</style>

<script>
  import { getSupabase, getCurrentUser, getCurrentProfile } from "../../../../lib/supabase";

  async function init() {
    const user = await getCurrentUser();
    if (!user) {
      window.location.href = "/lounge/login/?next=" + encodeURIComponent(window.location.pathname);
      return;
    }

    const profile = await getCurrentProfile();
    const guard = document.getElementById("lounge-guard") as HTMLElement;
    const content = document.getElementById("lounge-content") as HTMLElement;
    guard.hidden = true;
    content.hidden = false;

    const form = document.getElementById("submit-shop-form") as HTMLFormElement;
    const submitBtn = document.getElementById("ss-submit") as HTMLButtonElement;
    const status = document.getElementById("ss-status") as HTMLElement;
    const successBox = document.getElementById("ss-success") as HTMLElement;
    const againBtn = document.getElementById("ss-another") as HTMLButtonElement;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status.hidden = true;
      submitBtn.disabled = true;
      submitBtn.textContent = "Submitting…";

      const fd = new FormData(form);
      const payload = {
        shop_name: String(fd.get("shop_name") || "").trim(),
        city: String(fd.get("city") || "").trim(),
        country: String(fd.get("country") || "").trim(),
        address: String(fd.get("address") || "").trim() || null,
        can_smoke: String(fd.get("can_smoke") || "unknown"),
        notes: String(fd.get("notes") || "").trim() || null,
        submitted_by: user.id,
        submitter_email: user.email || null,
        submitter_name: (profile?.display_name as string) || null,
      };

      const supabase = getSupabase();
      const { error } = await supabase
        .from("community_submissions")
        .insert(payload);

      if (error) {
        console.error(error);
        status.hidden = false;
        status.textContent =
          "Couldn't submit. Try again, or email contact@thenextcigar.com directly with the shop details.";
        submitBtn.disabled = false;
        submitBtn.textContent = "Submit shop";
        return;
      }

      form.hidden = true;
      successBox.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = "Submit shop";
    });

    againBtn?.addEventListener("click", () => {
      form.reset();
      form.hidden = false;
      successBox.hidden = true;
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }

  init();
</script>
