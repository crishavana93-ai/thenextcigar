---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Set a password — The Lounge"
  description="Set or reset your password for The Lounge."
  noIndex
>
  <section class="lounge-auth">
    <div class="lounge-auth__inner reveal">
      <p class="lounge-auth__eyebrow">The Lounge · Password</p>
      <h1 class="lounge-auth__title">Set your password.</h1>
      <p class="lounge-auth__lead" id="reset-lead">
        Pick something memorable. Minimum 8 characters. You'll use this to sign in from now on.
      </p>

      <form id="reset-form" class="lounge-auth__form">
        <label class="lounge-auth__label">
          New password
          <input type="password" name="password" required minlength="8" autocomplete="new-password" placeholder="At least 8 characters" />
        </label>

        <label class="lounge-auth__label">
          Confirm new password
          <input type="password" name="password_confirm" required minlength="8" autocomplete="new-password" placeholder="Type it again" />
        </label>

        <button type="submit" class="lounge-auth__button">Save password →</button>
      </form>

      <p id="reset-status" class="lounge-auth__status" hidden></p>

      <p class="lounge-auth__alt">
        <a href="/lounge/login/">Back to sign in</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .lounge-auth {
    min-height: calc(100vh - 80px);
    background:
      radial-gradient(circle at 15% 25%, rgba(110, 38, 32, 0.10), transparent 55%),
      radial-gradient(circle at 85% 75%, rgba(255, 46, 46, 0.06), transparent 55%),
      var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
  }
  .lounge-auth__inner {
    width: 100%;
    max-width: 28rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 2.5rem;
  }
  .lounge-auth__eyebrow {
    font-size: 0.7rem; font-weight: 800; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--color-accent); margin: 0 0 0.85rem 0;
  }
  .lounge-auth__title {
    font-family: var(--font-display); font-size: 2.25rem; font-weight: 800;
    line-height: 1.05; letter-spacing: -0.02em;
    color: var(--color-text); margin: 0 0 0.85rem 0;
  }
  .lounge-auth__lead {
    font-size: 0.95rem; line-height: 1.55;
    color: var(--color-text-soft); margin: 0 0 1.5rem 0;
  }
  .lounge-auth__form { display: flex; flex-direction: column; gap: 1rem; }
  .lounge-auth__label {
    display: flex; flex-direction: column; gap: 0.4rem;
    font-size: 0.78rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--color-text-muted);
  }
  .lounge-auth__label input {
    padding: 0.75rem 0.85rem; border: 1px solid var(--color-border);
    border-radius: 3px; background: #fff; font-size: 0.95rem;
    color: var(--color-text); text-transform: none; letter-spacing: normal;
  }
  .lounge-auth__label input:focus { outline: 2px solid var(--color-accent); outline-offset: 1px; }
  .lounge-auth__button {
    margin-top: 0.4rem; padding: 0.65rem 1.2rem;
    background: var(--color-accent); color: #fff; border: none; border-radius: 999px;
    font-size: 0.76rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
    cursor: pointer; transition: background 0.15s ease;
  }
  .lounge-auth__button:hover { background: var(--color-accent-hover); }
  .lounge-auth__button:disabled { opacity: 0.6; cursor: wait; }
  .lounge-auth__status {
    margin-top: 1rem; padding: 0.85rem 1rem;
    background: var(--color-cream); border-left: 3px solid var(--color-accent);
    border-radius: 3px; font-size: 0.88rem; line-height: 1.5; color: var(--color-text);
  }
  .lounge-auth__status.is-error { background: #fde9e9; border-color: #c62828; }
  .lounge-auth__alt {
    margin-top: 1.25rem; text-align: center;
    font-size: 0.85rem; color: var(--color-text-muted);
  }
  .lounge-auth__alt a { color: var(--color-accent); font-weight: 600; text-decoration: underline; }
</style>

<script>
  import { getSupabase } from "../../lib/supabase";

  function showStatus(msg: string, isError = false) {
    const status = document.getElementById("reset-status") as HTMLParagraphElement | null;
    if (!status) return;
    status.hidden = false;
    status.classList.toggle("is-error", isError);
    status.innerHTML = msg;
  }

  async function setup() {
    const supabase = getSupabase();

    // When the user lands here from the password-reset email link, Supabase
    // (with detectSessionInUrl: true on implicit flow) picks up the recovery
    // token from the URL hash and creates a temporary session that's only
    // valid for one updateUser call. If no session exists by now, the link
    // expired or was clicked in a different browser session.
    //
    // We wait briefly so detectSessionInUrl can finish parsing the hash, then
    // verify a session exists.
    await new Promise((r) => setTimeout(r, 200));
    const { data: { session } } = await supabase.auth.getSession();
    const lead = document.getElementById("reset-lead") as HTMLParagraphElement;
    if (!session) {
      if (lead) {
        lead.innerHTML =
          `This reset link looks expired or already used. Head back to <a href="/lounge/login/" style="color:var(--color-accent);text-decoration:underline;">the sign-in page</a> and tap "First time? Set a password" again — we'll send a fresh email.`;
      }
      const form = document.getElementById("reset-form") as HTMLFormElement;
      if (form) form.hidden = true;
      return;
    }

    const form = document.getElementById("reset-form") as HTMLFormElement | null;
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const password = String(fd.get("password") || "");
      const confirm = String(fd.get("password_confirm") || "");
      if (password.length < 8) {
        showStatus("Password must be at least 8 characters.", true);
        return;
      }
      if (password !== confirm) {
        showStatus("The two passwords don't match.", true);
        return;
      }
      const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = "Saving…";
      try {
        const { error } = await supabase.auth.updateUser({ password });
        if (error) throw error;
        showStatus(`Password saved. Sending you to The Lounge…`);
        setTimeout(() => { window.location.href = "/lounge/app/"; }, 1200);
      } catch (err: any) {
        showStatus(err?.message || "Couldn't save password. Try again.", true);
        btn.disabled = false;
        btn.textContent = "Save password →";
      }
    });
  }

  document.addEventListener("astro:page-load", setup);
  setup();
</script>
