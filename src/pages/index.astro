---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import HighlightHero from "../components/HighlightHero.astro";
import CategoryBand from "../components/CategoryBand.astro";
import PremiumCTA from "../components/PremiumCTA.astro";
import AdSlot from "../components/AdSlot.astro";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const categories = await getCollection("categories");
const categoryByslug = new Map(categories.map((c) => [c.data.slug, c.data]));

// HIGHLIGHT NEWS — 1 featured + 2 side stories
const featured = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const featuredId = featured?.id;
const side = allPosts.filter((p) => p.id !== featuredId).slice(0, 2);

// LATEST NEWS — next 6 stories after the highlight section
const usedIds = new Set([featuredId, ...side.map((p) => p.id)]);
const latest = allPosts.filter((p) => !usedIds.has(p.id)).slice(0, 6);

// Helper — pull posts in a category. We allow re-use of posts that appeared in
// the highlight section so categories with few stories still render fully.
function postsByCategory(slug: string, limit = 4) {
  return allPosts.filter((p) => p.data.category === slug).slice(0, limit);
}

const cigar101 = postsByCategory("cigar-101");
const havana = postsByCategory("havana-cigar-life");
const culture = postsByCategory("cigar-culture");
const news = postsByCategory("latest-news");
---

<BaseLayout
  title="TNext Cigar — Modern editorial for the cigar aficionado"
  description="Highlight news, deep dives, and the cigar stories that shape the leaf — written for people who actually smoke them."
>
  {/* HIGHLIGHT NEWS — featured + 2 side stories */}
  {featured && (
    <HighlightHero featured={featured} side={side} categoryByslug={categoryByslug} />
  )}

  {/* LATEST NEWS — 6-up grid */}
  <section class="container-wide py-12 border-t border-[color:var(--color-border)]">
    <div class="flex items-end justify-between mb-10 reveal flex-wrap gap-4">
      <p class="section-eyebrow">Latest news</p>
      <a href="/blog" class="text-sm text-[color:var(--color-text-muted)] hover:text-[color:var(--color-accent)] transition-colors uppercase tracking-wider">
        See all {allPosts.length} stories →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
      {latest.map((post, i) => {
        const cat = post.data.category ? categoryByslug.get(post.data.category) : null;
        return <PostCard post={post} categoryName={cat?.name} delay={((i % 3) + 1) as 1 | 2 | 3} />;
      })}
    </div>
  </section>

  {/* AD: leaderboard */}
  <div class="container-wide py-8">
    <AdSlot variant="leaderboard" />
  </div>

  {/* WHAT'S HOT IN — Cigar 101 */}
  {cigar101.length > 0 && (
    <CategoryBand categoryName="Cigar 101" categorySlug="cigar-101" posts={cigar101} variant="dark" />
  )}

  {/* WHAT'S HOT IN — Havana Cigar Life (the Cuban content) */}
  {havana.length > 0 && (
    <CategoryBand categoryName="Havana Cigar Life" categorySlug="havana-cigar-life" posts={havana} />
  )}

  {/* AD: billboard */}
  <div class="container-wide py-8">
    <AdSlot variant="billboard" />
  </div>

  {/* WHAT'S HOT IN — Culture */}
  {culture.length > 0 && (
    <CategoryBand categoryName="Cigar Culture" categorySlug="cigar-culture" posts={culture} variant="warm" />
  )}

  {/* WHAT'S HOT IN — News */}
  {news.length > 0 && (
    <CategoryBand categoryName="Latest News" categorySlug="latest-news" posts={news} />
  )}

  {/* Premium CTA */}
  <PremiumCTA />
</BaseLayout>
