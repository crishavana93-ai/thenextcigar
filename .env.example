# ─── Supabase (The Lounge — required) ──────────────────────────────────────
# Get these from Supabase Dashboard → Settings → API.
# PUBLIC_ prefix is required so Astro exposes them to the browser.
# Both are safe to expose; the anon key is rate-limited and protected by RLS.
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_jwt_here

# ─── Snipcart (Shop — already in use) ───────────────────────────────────────
PUBLIC_SNIPCART_API_KEY=YOUR_PUBLIC_API_KEY

# ─── Optional: Mailerlite (used by NotifyMeForm) ────────────────────────────
# Already loaded inline in BaseLayout.astro; account ID 2332920
