# Copy this file to `.env` (no quotes, no spaces around =) and fill in the values.
# .env is gitignored — never commit your real token.

# Required: a Webflow API token.
# Get one at: https://webflow.com/dashboard/account/integrations  → "Generate API token"
# Scope: read access to CMS, Sites, Assets is enough.
WEBFLOW_API_TOKEN=

# Optional: the site ID for thenextcigar.com.
# If you have only one Webflow site under this account, leave this blank — the script will auto-detect.
# If you have multiple, run the script once with this blank; it will print every site ID, then rerun with the right one set.
WEBFLOW_SITE_ID=
